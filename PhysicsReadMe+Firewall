public enum DVSMReplicationOutcome {
    case success(newMeshID: UUID)
    case rejected(reason: String)
}

// =====================================================
// REPLICATION ENGINE
// =====================================================

public enum DVSMGlobalReplicationSpec {

    // -------------------------------------------------
    // 1. CLONE MESH (FORK WORLDLINE)
    // -------------------------------------------------

    public static func cloneMesh(
        snapshot: DVSMReplicationSnapshot
    ) -> DVSMReplicationOutcome {

        // Deterministic identity of new mesh derived from state
        let newMeshID = deriveMeshID(from: snapshot.systemHash, snapshot.worldlineHash)

        return .success(newMeshID: newMeshID)
    }

    // -------------------------------------------------
    // 2. DETECT FORK DIVERGENCE
    // -------------------------------------------------

    public static func detectDivergence(
        a: DVSMReplicationSnapshot,
        b: DVSMReplicationSnapshot
    ) -> Bool {

        return a.worldlineHash != b.worldlineHash
    }

    // -------------------------------------------------
    // 3. MERGE REPLICATION PATHS (L24 COMPATIBILITY RULE)
    // -------------------------------------------------

    public static func merge(
        primary: DVSMReplicationSnapshot,
        secondary: DVSMReplicationSnapshot
    ) -> DVSMReplicationSnapshot? {

        // Must share identical system contract (hard invariant)
        guard primary.systemHash == secondary.systemHash else {
            return nil
        }

        // deterministic merge rule: highest tick wins base state
        let selected = primary.tick >= secondary.tick ? primary : secondary

        return DVSMReplicationSnapshot(
            systemHash: selected.systemHash,
            worldlineHash: fold(primary.worldlineHash, secondary.worldlineHash),
            meshNodes: unify(primary.meshNodes, secondary.meshNodes),
            tick: max(primary.tick, secondary.tick)
        )
    }

    // -------------------------------------------------
    // 4. REPLICATION VALIDITY CHECK
    // -------------------------------------------------

    public static func validate(snapshot: DVSMReplicationSnapshot) -> Bool {

        return !snapshot.meshNodes.isEmpty &&
               snapshot.systemHash.count == 1
    }

    // -------------------------------------------------
    // INTERNAL HELPERS
    // -------------------------------------------------

    private static func deriveMeshID(from a: Data, _ b: Data) -> UUID {
        let combined = fold(a, b)
        var bytes = combined + Data(repeating: 0, count: 15)

        return UUID(uuid: (
            bytes[0], bytes[1], bytes[2], bytes[3],
            bytes[4], bytes[5], bytes[6], bytes[7],
            bytes[8], bytes[9], bytes[10], bytes[11],
            bytes[12], bytes[13], bytes[14], bytes[15]
        ))
    }

    private static func fold(_ a: Data, _ b: Data) -> Data {
        var acc: UInt8 = 0
        for x in a + b { acc ^= x }
        return Data([acc])
    }

    private static func unify(_ a: [DVSMNode], _ b: [DVSMNode]) -> [DVSMNode] {
        var set: [UUID: DVSMNode] = [:]

        for n in a + b {
            set[n.nodeID] = n
        }

        return Array(set.values)
    }
}

