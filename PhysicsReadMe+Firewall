public enum DVSMBinaryCodec {

    // MARK: - ENCODING ENTRYPOINT

    /**
     # CANONICAL SERIALIZER

     Produces a byte-exact representation of DVSMRawPulse.

     Layout (STRICT):
     [entity_id: u64]
     [delta.x: i64]
     [delta.y: i64]
     [delta.z: i64]
     [quote: 32 bytes]
     [entropy: u32]
     */
    public static func encode(_ pulse: DVSMRawPulse) -> Data {
        var buffer = Data(capacity: 72)

        appendUInt64(pulse.entity.entity_id, to: &buffer)

        appendInt64(pulse.delta.x, to: &buffer)
        appendInt64(pulse.delta.y, to: &buffer)
        appendInt64(pulse.delta.z, to: &buffer)

        buffer.append(contentsOf: pulse.quote.bytes)

        appendUInt32(pulse.entropy.entropy, to: &buffer)

        return buffer
    }

    // MARK: - HASH-CHAIN COMMITMENT

    /**
     # HASH-CHAIN STABLE DIGEST

     Ensures that any change in:
     - field order
     - byte encoding
     - struct layout
     breaks consensus immediately.
     */
    public static func hash(_ pulse: DVSMRawPulse) -> Data {
        let encoded = encode(pulse)

        var hasher = SHA256()
        hasher.update(data: encoded)

        return hasher.finalize().data
    }

    // MARK: - OPTIONAL DECODER (REPLAY MODE)

    public static func decode(_ data: Data) -> DVSMRawPulse {
        precondition(data.count == 72, "INVALID_BINARY_LENGTH")

        var offset = 0

        func readUInt64() -> UInt64 {
            let v = data.withUnsafeBytes { $0.load(fromByteOffset: offset, as: UInt64.self) }
            offset += 8
            return UInt64(littleEndian: v)
        }

        func readInt64() -> Int64 {
            let v = data.withUnsafeBytes { $0.load(fromByteOffset: offset, as: Int64.self) }
            offset += 8
            return Int64(littleEndian: v)
        }

        func readUInt32() -> UInt32 {
            let v = data.withUnsafeBytes { $0.load(fromByteOffset: offset, as: UInt32.self) }
            offset += 4
            return UInt32(littleEndian: v)
        }

        let entity = DVSMEntityID(entity_id: readUInt64())

        let delta = DVSMDelta3i64(
            x: readInt64(),
            y: readInt64(),
            z: readInt64()
        )

        let quoteBytes = [UInt8](data[offset..<offset+32])
        offset += 32

        let entropy = DVSMEntropy32(entropy: readUInt32())

        return DVSMRawPulse(
            entity: entity,
            delta: delta,
            quote: DVSMQuote32(bytes: quoteBytes),
            entropy: entropy
        )
    }

    // MARK: - BYTE PRIMITIVES (DETERMINISTIC LAYOUT)

    private static func appendUInt64(_ value: UInt64, to buffer: inout Data) {
        var v = value.littleEndian
        withUnsafeBytes(of: &v) { buffer.append(contentsOf: $0) }
    }

    private static func appendInt64(_ value: Int64, to buffer: inout Data) {
        var v = value.littleEndian
        withUnsafeBytes(of: &v) { buffer.append(contentsOf: $0) }
    }

    private static func appendUInt32(_ value: UInt32, to buffer: inout Data) {
        var v = value.littleEndian
        withUnsafeBytes(of: &v) { buffer.append(contentsOf: $0) }
    }
}

