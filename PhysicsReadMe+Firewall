// =====================================================
// DVSM ABI KERNEL (RUST SIDE)
// VERSION: ABI-V1-STABLE
// MUST MATCH SWIFT LOGIC BIT-FOR-BIT
// =====================================================

#[repr(C)]
#[derive(Copy, Clone)]
pub struct DVSMHash32 {
    pub bytes: [u8; 32],
}

#[repr(C)]
#[derive(Copy, Clone)]
pub struct DVSMExecutionPacket {
    pub input_hash: DVSMHash32,
    pub output_hash: DVSMHash32,
    pub tick: u64,
    pub node_id: [u8; 16],
}

#[repr(C)]
pub struct DVSMValidationResult {
    pub valid: u8,
    pub reason: [u8; 64],
}

// =====================================================
// HASH EQUALITY (STRICT BIT COMPARISON)
// =====================================================

fn hash_eq(a: &DVSMHash32, b: &DVSMHash32) -> bool {
    a.bytes == b.bytes
}

// =====================================================
// CORE VALIDATION LOGIC
// =====================================================

#[no_mangle]
pub extern "C" fn dvsm_validate_packet(
    packet: DVSMExecutionPacket,
    recomputed: DVSMHash32,
    swift_hash: DVSMHash32,
    rust_hash: DVSMHash32,
    wasm_hash: DVSMHash32
) -> DVSMValidationResult {

    let mut result = DVSMValidationResult {
        valid: 0,
        reason: [0; 64],
    };

    // -------------------------------------------------
    // 1. CROSS-RUNTIME DETERMINISM CHECK
    // -------------------------------------------------

    if !(hash_eq(&swift_hash, &rust_hash) && hash_eq(&rust_hash, &wasm_hash)) {
        let msg = b"runtime_divergence";
        result.reason[..msg.len()].copy_from_slice(msg);
        return result;
    }

    // -------------------------------------------------
    // 2. OUTPUT VALIDATION
    // -------------------------------------------------

    if !hash_eq(&packet.output_hash, &recomputed) {
        let msg = b"output_mismatch";
        result.reason[..msg.len()].copy_from_slice(msg);
        return result;
    }

    // -------------------------------------------------
    // 3. VALID STATE
    // -------------------------------------------------

    result.valid = 1;
    let msg = b"ok";
    result.reason[..msg.len()].copy_from_slice(msg);

    result
}

