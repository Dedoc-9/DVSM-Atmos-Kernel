// =====================================================
// MARK: - TRACE KERNEL
// =====================================================

public enum DVSMExecutionTraceKernel {

    // -------------------------------------------------
    // LIVE EXECUTION ENTRYPOINT
    // -------------------------------------------------

    public static func execute(
        initialMemory: Data,
        operations: [DVSMTraceOperation]
    ) -> DVSMReplayResult {

        var memory = initialMemory
        var events: [DVSMTraceEvent] = []

        for (tick, operation) in operations.enumerated() {

            // PRE-STATE HASH
            let preHash = DVSMHashing.sha256(memory)

            // APPLY OPERATION
            let nextMemory = DVSMMemoryEngine.apply(
                memory: memory,
                op: operation.op
            )

            // POST-STATE HASH
            let postHash = DVSMHashing.sha256(nextMemory)

            // BUILD TRACE EVENT
            let event = DVSMTraceEvent(
                tick: UInt64(tick),
                operation: operation,
                preStateHash: preHash,
                postStateHash: postHash
            )

            events.append(event)

            // ADVANCE STATE
            memory = nextMemory
        }

        // FINAL CANONICAL HASH
        let canonical = DVSMCanonicalTraceHasher.hash(events)

        return DVSMReplayResult(
            finalMemory: memory,
            trace: events,
            canonicalHash: canonical,
            valid: true
        )
    }

    // -------------------------------------------------
    // DETERMINISTIC REPLAY
    // -------------------------------------------------

    public static func replay(
        initialMemory: Data,
        trace: [DVSMTraceEvent]
    ) -> DVSMReplayResult {

        var memory = initialMemory

        for event in trace {

            // VERIFY PRE-STATE
            let currentHash = DVSMHashing.sha256(memory)

            guard currentHash == event.preStateHash else {
                return .failure(reason: "pre_state_mismatch")
            }

            // RE-EXECUTE OPERATION
            let next = DVSMMemoryEngine.apply(
                memory: memory,
                op: event.operation.op
            )

            // VERIFY POST-STATE
            let nextHash = DVSMHashing.sha256(next)

            guard nextHash == event.postStateHash else {
                return .failure(reason: "post_state_mismatch")
            }

            memory = next
        }

        let canonical = DVSMCanonicalTraceHasher.hash(trace)

        return DVSMReplayResult(
            finalMemory: memory,
            trace: trace,
            canonicalHash: canonical,
            valid: true
        )
    }
}

