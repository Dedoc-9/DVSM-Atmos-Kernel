 Detect coordinated multi-node poisoning campaigns and dynamically
 reconfigure the trust graph to isolate adversarial sub-networks.

 CORE IDEA:
 Adversaries are not individual nodes—they are correlated structures.
 The system must detect *graph-level intent*, not just node-level failure.
 */

// MARK: - TRUST GRAPH MODEL

public struct DVSMTrustEdge {
    public let from: UUID
    public let to: UUID
    public var weight: Double          // trust influence strength
    public var correlationScore: Double // behavioral similarity
}

public struct DVSMTrustGraph {
    public var nodes: Set<UUID>
    public var edges: [DVSMTrustEdge]
}

// MARK: - ADVERSARIAL CLUSTER MODEL

public struct DVSMAdversarialCluster {
    public let members: Set<UUID>
    public let coherenceScore: Double     // how tightly synchronized behavior is
    public let anomalySignature: Data     // hash of shared behavior pattern
}

// MARK: - L14.6 ENGINE

public enum DVSMTrustTopologyHealer {

    /**
     # COORDINATED ATTACK DETECTOR

     Detects groups of nodes whose behavior is statistically
     too similar to be independent.
     */
    public static func detectClusters(
        graph: DVSMTrustGraph,
        similarityThreshold: Double = 0.85
    ) -> [DVSMAdversarialCluster] {
        
        var clusters: [DVSMAdversarialCluster] = []
        var visited: Set<UUID> = []

        for node in graph.nodes where !visited.contains(node) {
            
            let group = graph.edges
                .filter { $0.from == node || $0.to == node }
                .filter { $0.correlationScore > similarityThreshold }
                .map { $0.from == node ? $0.to : $0.from }

            let clusterMembers = Set(group).union([node])

            guard clusterMembers.count > 1 else { continue }

            visited.formUnion(clusterMembers)

            let coherence = clusterCoherence(clusterMembers, graph: graph)

            let signature = generateClusterSignature(clusterMembers)

            clusters.append(
                DVSMAdversarialCluster(
                    members: clusterMembers,
                    coherenceScore: coherence,
                    anomalySignature: signature
                )
            )
        }

        return clusters
    }

    /**
     # GRAPH HEALING OPERATOR

     Rewrites trust edges to isolate or weaken adversarial clusters
     without collapsing the entire network.
     */
    public static func heal(
        graph: inout DVSMTrustGraph,
        clusters: [DVSMAdversarialCluster]
    ) {
        
        for cluster in clusters {
            
            // 1. ISOLATION: Reduce inter-cluster influence
            graph.edges = graph.edges.map { edge in
                
                let inClusterA = cluster.members.contains(edge.from)
                let inClusterB = cluster.members.contains(edge.to)

                if inClusterA && inClusterB {
                    // internal cluster reinforcement is dampened if adversarial
                    var modified = edge
                    modified.weight *= 0.2
                    return modified
                }

                if inClusterA || inClusterB {
                    // cross-boundary trust is heavily reduced
                    var modified = edge
                    modified.weight *= 0.05
                    return modified
                }

                return edge
            }
        }
    }

    /**
     # EMERGENCY QUARANTINE LAYER

     Completely isolates clusters that exceed adversarial threshold.
     */
    public static func quarantine(
        graph: inout DVSMTrustGraph,
        clusters: [DVSMAdversarialCluster],
        threshold: Double = 0.92
    ) -> Set<UUID> {
        
        var quarantined: Set<UUID> = []

        for cluster in clusters where cluster.coherenceScore > threshold {
            
            quarantined.formUnion(cluster.members)

            // Remove all edges touching quarantined nodes
            graph.edges.removeAll { edge in
                cluster.members.contains(edge.from) ||
                cluster.members.contains(edge.to)
            }
        }

        return quarantined
    }

    // MARK: - INTERNAL ANALYTICS

    private static func clusterCoherence(
        _ members: Set<UUID>,
        graph: DVSMTrustGraph
    ) -> Double {
        let edges = graph.edges.filter {
            members.contains($0.from) && members.contains($0.to)
        }

        guard !edges.isEmpty else { return 0.0 }

        return edges.map { $0.correlationScore }.reduce(0, +) / Double(edges.count)
    }

    private static func generateClusterSignature(
        _ members: Set<UUID>
    ) -> Data {
        let sorted = members.map { $0.uuidString }.sorted().joined()
        return SHA256.hash(data: Data(sorted.utf8)).data
    }
}

