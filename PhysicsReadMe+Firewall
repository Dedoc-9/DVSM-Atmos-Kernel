        var capHasher = SHA256()
        for c in capabilities.sorted(by: { $0.rawValue < $1.rawValue }) {
            var v = c.rawValue.bigEndian
            capHasher.update(data: Data(bytes: &v, count: 8))
        }
        let capabilityHash = capHasher.finalize().data

        // 3. History binding
        var historyHasher = SHA256()
        historyHasher.update(data: history.ledgerFinalityHash)
        var anchor = history.spatialEquivalenceAnchor.bigEndian
        historyHasher.update(data: Data(bytes: &anchor, count: 8))
        let historyHash = historyHasher.finalize().data

