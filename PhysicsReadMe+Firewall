// =====================================================

public enum DVSMTraceSigning {

    public static func sign(
        trace: DVSMReplayTrace,
        privateKey: P256.Signing.PrivateKey
    ) -> DVSMConsensusMessage {

        let payload = canonicalize(trace)

        let hash = Data(SHA256.hash(data: payload))

        let signature = try! privateKey.signature(for: hash)

        let node = DVSMNodeID(
            publicKeyHash: Data(SHA256.hash(data: privateKey.publicKey.derRepresentation))
        )

        return DVSMConsensusMessage(
            sender: node,
            trace: trace,
            signature: signature.derRepresentation
        )
    }

    public static func verify(
        message: DVSMConsensusMessage,
        publicKey: P256.Signing.PublicKey
    ) -> Bool {

        let payload = canonicalize(message.trace)

        let hash = Data(SHA256.hash(data: payload))

        return publicKey.isValidSignature(message.signature, for: hash)
    }

    private static func canonicalize(_ trace: DVSMReplayTrace) -> Data {

        var data = Data()

        trace.tickHashes.forEach { data.append($0) }

        data.append(trace.finalStateHash)

        data.append(trace.configHash)

        return data
    }
}

// =====================================================
// 5. CONSENSUS STATE MODEL
// =====================================================

public enum DVSMConsensusState {

    case pending
    case accepted
    case rejected
}

// =====================================================
// 6. REPLAY CONSENSUS ENGINE
// =====================================================

public final class DVSMReplayConsensusEngine {

    private var received: [DVSMConsensusMessage] = []

    // ---------------------------------------------
    // ACCEPT MESSAGE
    // ---------------------------------------------

    public func submit(_ message: DVSMConsensusMessage) {

        received.append(message)
    }

    // ---------------------------------------------
    // CONSENSUS EVALUATION
    // ---------------------------------------------

    public func evaluateConsensus() -> DVSMConsensusState {

        guard !received.isEmpty else {
            return .pending
        }

        // ------------------------------------------------
        // STEP 1: ALL CONFIGS MUST MATCH
        // ------------------------------------------------

        let firstConfig = received[0].trace.configHash

        for msg in received {
            if msg.trace.configHash != firstConfig {
                return .rejected
            }
        }

        // ------------------------------------------------
        // STEP 2: FINAL STATE MUST MATCH
        // ------------------------------------------------

        let final = received[0].trace.finalStateHash

        for msg in received {
            if msg.trace.finalStateHash != final {
                return .rejected
            }
        }

        // ------------------------------------------------
        // STEP 3: TRACE STRUCTURE MUST MATCH
        // ------------------------------------------------

        let reference = received[0].trace.tickHashes

        for msg in received {

            if msg.trace.tickHashes != reference {
                return .rejected
            }
        }

        return .accepted
    }
}

// =====================================================
// 7. NETWORK MODEL (GOSSIP REPLAY SYNC)
// =====================================================

public final class DVSMReplayNetwork {

    private var nodes: [DVSMNodeID: DVSMReplayConsensusEngine] = [:]

    // ---------------------------------------------
    // REGISTER NODE
    // ---------------------------------------------

    public func register(node: DVSMNodeID) {

        nodes[node] = DVSMReplayConsensusEngine()
    }

    // ---------------------------------------------
    // BROADCAST TRACE
    // ---------------------------------------------

    public func broadcast(
        message: DVSMConsensusMessage
    ) {

        for (_, engine) in nodes {
            engine.submit(message)
        }
    }

    // ---------------------------------------------
    // GLOBAL CONSENSUS CHECK
    // ---------------------------------------------

    public func globalConsensus() -> DVSMConsensusState {

        var states: [DVSMConsensusState] = []

        for (_, engine) in nodes {
            states.append(engine.evaluateConsensus())
        }

        if states.contains(.rejected) {
            return .rejected
        }

        if states.allSatisfy({ $0 == .accepted }) {
            return .accepted
        }

        return .pending
    }
}

