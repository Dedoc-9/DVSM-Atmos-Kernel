        let entropyStable = abs(state.entropy - next.entropy) < 0.0001
        let trustStable = state.trustDistribution == next.trustDistribution
        let worldlineStable = state.worldlineCount == next.worldlineCount

        return entropyStable && trustStable && worldlineStable
