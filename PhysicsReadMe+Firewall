// =================================================

public func detectForks(worldline: UUID) -> [[DVSMCausalEvent]] {

    let chain = replay(worldline: worldline)

    guard chain.count > 1 else { return [chain] }

    var forks: [[DVSMCausalEvent]] = []
    var currentBranch: [DVSMCausalEvent] = []

    var lastTick: UInt64 = chain.first?.tick ?? 0

    for event in chain {

        // divergence rule: tick regression or mismatched parent continuity
        if event.tick < lastTick {
            forks.append(currentBranch)
            currentBranch = []
        }

        currentBranch.append(event)
        lastTick = event.tick
    }

    forks.append(currentBranch)

    return forks
}

