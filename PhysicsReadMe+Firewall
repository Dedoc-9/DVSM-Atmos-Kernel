public enum DVSMWASMAttestation {

    public struct SignedBinary {

        public let wasmHash: Data
        public let signature: Data
        public let publicKey: Data
    }

    // ---------------------------------------------
    // SIGN BINARY
    // ---------------------------------------------

    public static func sign(
        wasmBinary: Data,
        privateKey: P256.Signing.PrivateKey
    ) -> SignedBinary {

        let hash = Data(SHA256.hash(data: wasmBinary))

        let signature = try! privateKey.signature(for: hash)

        return SignedBinary(
            wasmHash: hash,
            signature: signature.derRepresentation,
            publicKey: privateKey.publicKey.derRepresentation
        )
    }

    // ---------------------------------------------
    // VERIFY BINARY
    // ---------------------------------------------

    public static func verify(
        binary: SignedBinary
    ) -> Bool {

        guard let publicKey =
            try? P256.Signing.PublicKey(
                derRepresentation: binary.publicKey
            ) else {
            return false
        }

        return publicKey.isValidSignature(
            binary.signature,
            for: binary.wasmHash
        )
    }
}

