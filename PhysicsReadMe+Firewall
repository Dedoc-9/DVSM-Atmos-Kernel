    // -------------------------------------------------

    public enum Offset {
        public static let entityID      = 0x0000
        public static let deltaX        = 0x0010
        public static let morphismSeed  = 0x0018
        public static let headerEnd      = 0x0020
    }

    // -------------------------------------------------
    // ENTITY ID ACCESS
    // -------------------------------------------------

    public static func readEntityID(_ memory: Data) -> (UInt64, UInt64) {
        let slice = memory.subdata(in: Offset.entityID..<Offset.entityID+16)
        return slice.withUnsafeBytes {
            let ptr = $0.bindMemory(to: UInt64.self)
            return (ptr[0], ptr[1])
        }
    }

    // -------------------------------------------------
    // DELTA X ACCESS
    // -------------------------------------------------

    public static func readDeltaX(_ memory: Data) -> Int64 {
        let slice = memory.subdata(in: Offset.deltaX..<Offset.deltaX+8)
        return slice.withUnsafeBytes { $0.load(as: Int64.self) }
    }

    // -------------------------------------------------
    // MORPHISM SEED ACCESS
    // -------------------------------------------------

    public static func readMorphismSeed(_ memory: Data) -> UInt64 {
        let slice = memory.subdata(in: Offset.morphismSeed..<Offset.morphismSeed+8)
        return slice.withUnsafeBytes { $0.load(as: UInt64.self) }
    }
}

