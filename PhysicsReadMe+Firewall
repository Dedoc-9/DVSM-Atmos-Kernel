public enum DVSMProofVerifier {

/// Recomputes selection from raw inputs and compares against provided proof
public static func verify<T: Comparable>(
    inputs: [T],
    result: DVSMSelectionResult<T>
) -> Bool {

    do {
        let reconstructed = try reconstruct(inputs: inputs, proof: result.proof)

        // Final value must match reconstructed deterministic result
        return reconstructed == result.value
    } catch {
        return false
    }
}

// =================================================
// MARK: - FULL RECONSTRUCTION PIPELINE
// =================================================

private static func reconstruct<T: Comparable>(
    inputs: [T],
    proof: DVSMSelectionProof
) throws -> T {

    guard !inputs.isEmpty else {
        throw DVSMProofError.inputMismatch
    }

    // 1. Validate rule fingerprint (hard identity check)
    let expectedRule = SHA256.hash(
        data: "DVSM_DETERMINISTIC_V1".data(using: .utf8)!
    ).data

    guard proof.ruleFingerprint.hash == expectedRule else {
        throw DVSMProofError.ruleMismatch
    }

    // 2. Rebuild deterministic ordering
    let sorted = inputs.enumerated().sorted { a, b in
        if a.element != b.element {
            return a.element < b.element
        }
        return a.offset < b.offset
    }

    let reconstructedIndices = sorted.map { UInt64($0.offset) }

    // 3. Validate ordering trace
    guard reconstructedIndices == proof.orderingTrace.indices else {
        throw DVSMProofError.orderingMismatch
    }

    // 4. Validate input fingerprint
    let inputHash = SHA256.hash(data: Data(inputs.description.utf8)).data
    guard inputHash == proof.inputFingerprint.hash else {
        throw DVSMProofError.inputMismatch
    }

    // 5. Deterministic selection (same logic as selector)
    guard let winner = sorted.first else {
        throw DVSMProofError.invalidProofStructure
    }

    // 6. Validate output binding
    let outputHash = SHA256.hash(
        data: Data(String(describing: winner.element).utf8)
    ).data

    guard outputHash == proof.outputHash else {
        throw DVSMProofError.outputMismatch
    }

    // 7. Return reconstructed canonical value
    return winner.element
}

}

