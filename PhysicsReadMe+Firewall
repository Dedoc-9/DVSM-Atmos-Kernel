// -----------------------------------------------------
// ATTESTATION STRUCTURES
// -----------------------------------------------------

public struct DVSMAttestation {
    public let nodeID: UUID
    public let systemHash: Data
    public let signature: Data
    public let tick: UInt64
}

// -----------------------------------------------------
// SIGNING INTERFACE (ABSTRACTED CRYPTO LAYER)
// -----------------------------------------------------

public protocol DVSMNodeSigner {
    func sign(data: Data) -> Data
}

// =====================================================
// ATTESTATION ENGINE
// =====================================================

public enum DVSMAttestationProtocol {

    // -------------------------------------------------
    // CREATE ATTESTATION FOR SYSTEM STATE
    // -------------------------------------------------

    public static func createAttestation(
        nodeID: UUID,
        signer: DVSMNodeSigner,
        systemHash: Data,
        tick: UInt64
    ) -> DVSMAttestation {

        let payload = systemHash + tick.bigEndianData()
        let signature = signer.sign(data: payload)

        return DVSMAttestation(
            nodeID: nodeID,
            systemHash: systemHash,
            signature: signature,
            tick: tick
        )
    }

    // -------------------------------------------------
    // VERIFY SINGLE ATTESTATION
    // -------------------------------------------------

    public static func verify(attestation: DVSMAttestation,
                              signer: DVSMNodeSigner) -> Bool {

        let expected = signer.sign(data: attestation.systemHash + attestation.tick.bigEndianData())
        return expected == attestation.signature
    }

    // -------------------------------------------------
    // COLLECTIVE AGREEMENT CHECK (L24 FINALITY RULE)
    // -------------------------------------------------

    public static func isCanonical(
        attestations: [DVSMAttestation],
        requiredQuorum: Int
    ) -> Bool {

        guard attestations.count >= requiredQuorum else {
            return false
        }

        // All attestations must agree on identical system hash
        let firstHash = attestations.first!.systemHash

        let allMatch = attestations.allSatisfy {
            $0.systemHash == firstHash
        }

        return allMatch
    }

    // -------------------------------------------------
    // FINAL CANONICAL SELECTION
    // -------------------------------------------------

    public static func selectCanonical(
        attestations: [DVSMAttestation]
    ) -> DVSMAttestation? {

        return attestations
            .sorted { $0.tick > $1.tick }
            .first
    }
}

// =====================================================
// EXTENSIONS
// =====================================================

extension UInt64 {
    func bigEndianData() -> Data {
        var value = self.bigEndian
        return Data(bytes: &value, count: MemoryLayout<UInt64>.size)
    }
}

extension Data {
    static func + (lhs: Data, rhs: Data) -> Data {
        var copy = lhs
        copy.append(rhs)
        return copy
    }
}

