        // 5. apply law evolution
        state.lawState = DVSMLawState(
            stability: proposedDelta.proposedStability,
            lawHash: state.lawState.lawHash
        )

        // 6. recompute world state hash deterministically
        state.worldHash = computeWorldHash(state, meshes: cleanedMeshes)

        // 7. advance tick
        state.tick &+= 1
    }

    // -------------------------------------------------
    // NO-MUTATION PATH (SAFE ADVANCE)
    // -------------------------------------------------

    private func advanceTickWithoutMutation(
        state: inout State,
        meshes: [DVSMMesh]
    ) {
        state.worldHash = computeWorldHash(state, meshes: meshes)
        state.tick &+= 1
    }

    // -------------------------------------------------
    // DETERMINISTIC WORLD HASH FUNCTION
    // -------------------------------------------------

    private func computeWorldHash(
        _ state: State,
        meshes: [DVSMMesh]
    ) -> Data {

        var acc: UInt8 = 0

        acc ^= UInt8(state.tick & 0xFF)
        acc ^= state.lawState.lawHash.first ?? 0

        for m in meshes {
            acc ^= m.headHash.first ?? 0
            acc ^= UInt8(m.trustWeight & 0xFF)
        }

        return Data([acc])
    }
