    public static func updateTrust(
        profile: inout DVSMPredictionTrustProfile,
        signal: DVSMAdversarialSignal
    ) {
        
        let accuracy = max(0.0, 1.0 - signal.divergenceMagnitude)
        
        // Exponential smoothing for stability
        profile.trustScore = (profile.trustScore * 0.9) + (accuracy * 0.1)
        
        // Penalize repeated deviation patterns
        profile.deviationPenalty += signal.anomalyScore * signal.divergenceMagnitude
        
        // Clamp to valid bounds
        profile.trustScore = min(max(profile.trustScore, 0.0), 1.0)
    }

    /**
