                return nil // No collision at this tick
            }
            
            let confidenceMap = group.reduce(into: [Data: Double]()) { acc, p in
                acc[p.predictedStateHash, default: 0] += p.confidence
            }
            
            return DVSMFutureCollision(
                tick: tick,
                competingStates: Array(uniqueStates),
                confidenceMap: confidenceMap
            )
        }
    }

    /**
     # COLLISION RESOLUTION RULE (L14.4-R)

     The canonical future is selected via:
     1. Highest aggregate confidence
     2. If tie → lexicographical hash order
     */
    public static func resolveCanonicalFuture(
        collision: DVSMFutureCollision
    ) -> Data? {
        
        let sorted = collision.confidenceMap.sorted {
            if $0.value != $1.value {
                return $0.value > $1.value
            }
            return $0.key.lexicographicallyPrecedes($1.key)
        }
        
        return sorted.first?.key
    }
}

The key conceptual shift

Most systems do:
observe → reconcile → fix

This stack (with L14.4) does:
propose → predict-collide → resolve → execute

So it moves conflict resolution one temporal step earlier.

