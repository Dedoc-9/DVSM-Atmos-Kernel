 1. PROBE NORMALIZATION:
    Observed jitter is mapped into canonical deterministic domain.

 2. PROPORTIONAL DEGRADATION:
    Trust is multiplicative and bounded [0,1].

 3. FIXED-POINT REPLAY SAFETY:
    All adaptive scalars are quantized before entering hash space.

 4. STATE INTEGRATION:
    ALL adaptive parameters are committed into L5 state evolution.
 */

public final class DVSMKernel {

    private var currentState: DVSMStateHeader

    // =====================================================
    // FIXED-POINT CANONICALIZATION (L5 SAFETY LAYER)
    // =====================================================
    private func quantize(_ value: Double) -> Int64 {
        // 32.32 fixed-point representation (deterministic across platforms)
        return Int64(value * Double(1 << 32))
    }

    private func dequantize(_ value: Int64) -> Double {
        return Double(value) / Double(1 << 32)
    }

    // =====================================================
    // MAIN PULSE FUNCTION
    // =====================================================
    public func pulse(
        raw: Data,
        substrate: L10SubstrateState,
        map: L2VoxelMap
    ) -> DVSMExecutionResult {

        // -------------------------------------------------
        // A. L10.4 DETERMINISTIC PROBE (EXPECTATION MODEL)
        // -------------------------------------------------
        let expectedJitter = DVSMThermalBreathVerifier.generateProbe(
            seed: currentState.morphismSeed
        )

        // -------------------------------------------------
        // B. CANONICAL NORMALIZATION (REPLAY SAFE)
        // -------------------------------------------------
        let normalizedObserved = DVSMThermalBreathVerifier.normalize(
            substrate.executionJitter
        )

        // -------------------------------------------------
        // C. L10 TRUST FUSION (STABLE FORMULATION)
        // -------------------------------------------------
        let rawTrust = L10ContinuousMonitor.evaluate(state: substrate)

        let livenessPenalty = DVSMThermalBreathVerifier.computePenalty(
            observed: normalizedObserved,
            expected: expectedJitter
        )

        let governedTrust = rawTrust * (1.0 - livenessPenalty)

        // FIX: quantized precision modifier (REPLAY SAFE)
        let precisionModifier = max(0.5, min(1.0, governedTrust))
        let qPrecisionModifier = dequantize(quantize(precisionModifier))

        // -------------------------------------------------
        // D. L1 STRUCTURAL DECODING
        // -------------------------------------------------
        guard let decoded = DVSMHardenedMirror.decode(raw) else {
            return .rejected(reason: .structuralViolation)
        }

        // -------------------------------------------------
        // E. L2 GEOMETRIC VALIDATION
        // -------------------------------------------------
        let isAdmissible = DVSMGeometricKernel.validate(
            decoded,
            map: map,
            multiplier: qPrecisionModifier
        )

        // -------------------------------------------------
        // F. EXECUTION DECISION
        // -------------------------------------------------
        guard governedTrust >= 0.5 else {
            return .rejected(reason: .nondeterminismDetected)
        }

        guard isAdmissible else {
            return .rejected(reason: .causalOrphan)
        }

        // -------------------------------------------------
        // G. STATE EVOLUTION (L5 FULL TRACE INTEGRATION)
        // -------------------------------------------------
        self.evolve(
            with: raw,
            modifier: qPrecisionModifier,
            trust: governedTrust
        )

        return .committed
    }

    // =====================================================
    // STATE EVOLUTION (FULL DETERMINISTIC TRACE)
    // =====================================================
    private func evolve(
        with input: Data,
        modifier: Double,
        trust: Double
    ) {

        let modFixed = quantize(modifier)
        let trustFixed = quantize(trust)

        let newHash = DVSMKernel.evolveHash(
            currentState.stateHash,
            input,
            modFixed,
            trustFixed
        )

        self.currentState = DVSMStateHeader(
            sequence: currentState.sequence + 1,
            stateHash: newHash,
            faultStatus: .clean,
            morphismSeed: DVSMSeedEngine.next(
                currentState.morphismSeed,
                input
            ),
            attestationHash: currentState.attestationHash
        )
    }
}
