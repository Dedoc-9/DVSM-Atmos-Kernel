public enum DVSMTraceReplayEngine {

    /// Replays execution state for a specific tick
    public static func replay(
        ledger: DVSMTraceLedger,
        tick: UInt64
    ) -> DVSMReplaySnapshot {

        let events = ledger.events(for: tick)

        guard !events.isEmpty else {
            return DVSMReplaySnapshot(tick: tick, valid: false, reason: "no_events")
        }

        // Cross-runtime consistency check
        let hashes = Set(events.map { $0.outputHash })

        if hashes.count > 1 {
            return DVSMReplaySnapshot(
                tick: tick,
                valid: false,
                reason: "runtime_divergence_detected"
            )
        }

        return DVSMReplaySnapshot(
            tick: tick,
            valid: true,
            reason: nil
        )
    }

    /// Finds first divergence point in system execution
    public static func findDivergence(
        ledger: DVSMTraceLedger
    ) -> UInt64? {

        let grouped = Dictionary(grouping: ledger.fullTrace(), by: { $0.tick })

        for tick in grouped.keys.sorted() {
            let hashes = Set(grouped[tick]!.map { $0.outputHash })
            if hashes.count > 1 {
                return tick
            }
        }

        return nil
    }
}

