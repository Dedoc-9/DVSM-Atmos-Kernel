extension DVSMSystemHeader {

    /**
     # DCAL-VALIDATED SELECTION RULE (HARDENED)

     A fork is eligible for Canonical Collapse ONLY IF:
     1. It satisfies quorum signatures
     2. It is within the temporal window
     3. Its weight is cryptographically DERIVED (not declared)
     */
    public static func resolveDCALHead(
        forks: [(DVSMFork, DVSMConsensusAttestation)],
        currentTick: UInt64,
        quorumK: Int,
        windowDelta: UInt64 = 10
    ) -> DVSMFork? {

        let eligibleForks: [(DVSMFork, UInt64)] = forks.compactMap { (fork, att) in

            // 1. Quorum Check
            guard att.signatures.count >= quorumK else { return nil }

            // 2. Temporal Window Check (L4 bounded causality)
            guard att.tick <= currentTick,
                  att.tick >= currentTick - windowDelta else { return nil }

            // 3. Signature Canonicalization Check (deterministic ordering)
            let canonicalSignatures = att.signatures
                .sorted { $0.key.lexicographicallyPrecedes($1.key) }

            // 4. Weight MUST be derived (not supplied)
            let derivedWeight = deriveWeight(
                forkHeadHash: att.forkHeadHash,
                signatures: canonicalSignatures,
                tick: att.tick
            )

            return (fork, derivedWeight)
        }

        // Apply deterministic L14 selection rule over DCAL-valid set
        return eligibleForks.max { a, b in
            DVSMConsensusCollapse.isMoreCanonical(
                forkA: a.0,
                weightA: a.1,
                forkB: b.0,
                weightB: b.1
            )
        }?.0
    }

    // MARK: - PURE WEIGHT DERIVATION (NO EXTERNAL AUTHORITY)

    private static func deriveWeight(
        forkHeadHash: Data,
        signatures: [(key: Data, value: Data)],
        tick: UInt64
    ) -> UInt64 {

        var hasher = SHA256()

        hasher.update(data: forkHeadHash)
        hasher.update(data: tick.bigEndianData)

        for sig in signatures {
            hasher.update(data: sig.key)
            hasher.update(data: sig.value)
        }

        let digest = hasher.finalize()

        // Compress hash → UInt64 deterministically (first 8 bytes)
        return digest.withUnsafeBytes { ptr in
            ptr.load(as: UInt64.self)
        }
    }
