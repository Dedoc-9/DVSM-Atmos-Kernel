public enum DVSMTrustClass {
    case sovereign      // full authority (rare / root nodes)
    case validator      // participates in consensus
    case observer       // read-only verification
}

// MARK: - ALLOWED REPAIR RULES PER CLASS

public struct DVSMConstitutionRuleSet {

    public let allowedRepairStrategies: Set<DVSMRepairStrategy>
    public let maxAllowedDivergenceTicks: UInt64
    public let canOverrideRustAuthority: Bool
    public let requiresMultiNodeApproval: Bool
}

// =====================================================
// CONSTITUTION REGISTRY
// =====================================================

public enum DVSMConstitution {

    // -------------------------------------------------
    // CORE RULE DEFINITIONS
    // -------------------------------------------------

    public static func rules(for trust: DVSMTrustClass) -> DVSMConstitutionRuleSet {

        switch trust {

        case .sovereign:
            return DVSMConstitutionRuleSet(
                allowedRepairStrategies: [.majorityHash, .rustAuthority, .earliestValidTick],
                maxAllowedDivergenceTicks: 1_000,
                canOverrideRustAuthority: true,
                requiresMultiNodeApproval: false
            )

        case .validator:
            return DVSMConstitutionRuleSet(
                allowedRepairStrategies: [.majorityHash, .rustAuthority],
                maxAllowedDivergenceTicks: 100,
                canOverrideRustAuthority: false,
                requiresMultiNodeApproval: true
            )

        case .observer:
            return DVSMConstitutionRuleSet(
                allowedRepairStrategies: [],
                maxAllowedDivergenceTicks: 0,
                canOverrideRustAuthority: false,
                requiresMultiNodeApproval: true
            )
        }
    }

