// MARK: - PROOF GENERATOR

public enum DVSMCausalProofEngine {

    public static func generate(
        sequence: UInt64,
        input: Data,
        stateHash: Data,
        capabilities: [DVSMCapability],
        history: DVSMHistoryClass,
        trust: Double
    ) -> DVSMCausalProof {

        // 1. Normalize trust into L4 tick domain
        let trustTick = DVSMClock.quantize(UInt64(trust * 1_000_000))

        // 2. Capability commitment (order-stable)
        var capHasher = SHA256()
        for c in capabilities.sorted(by: { $0.rawValue < $1.rawValue }) {
            var v = c.rawValue.bigEndian
            capHasher.update(data: Data(bytes: &v, count: 8))
        }
        let capabilityHash = capHasher.finalize().data

        // 3. History binding
        var historyHasher = SHA256()
        historyHasher.update(data: history.ledgerFinalityHash)
        var anchor = history.spatialEquivalenceAnchor.bigEndian
        historyHasher.update(data: Data(bytes: &anchor, count: 8))
        let historyHash = historyHasher.finalize().data

        // 4. Final proof binding
        var finalHasher = SHA256()
        finalHasher.update(data: input)
        finalHasher.update(data: stateHash)
        finalHasher.update(data: capabilityHash)
        finalHasher.update(data: historyHash)

        var tickBytes = trustTick.bigEndian
        finalHasher.update(data: Data(bytes: &tickBytes, count: 8))

        let proofHash = finalHasher.finalize().data

        return DVSMCausalProof(
            sequence: sequence,
            inputHash: input.sha256,
            stateHash: stateHash,
            capabilityHash: capabilityHash,
            historyClassHash: historyHash,
            trustTick: trustTick,
            proofHash: proofHash
        )
    }
}


