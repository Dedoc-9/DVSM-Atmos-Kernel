    let current_x = read_i64(ENTITY_X_OFFSET);

    let current_y = read_i64(ENTITY_Y_OFFSET);

    let velocity_x = read_i64(VELOCITY_X_OFFSET);

    let velocity_y = read_i64(VELOCITY_Y_OFFSET);

    // -------------------------------------------------
