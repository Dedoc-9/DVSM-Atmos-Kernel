public enum DVSMCanonicalTraceHasher {

    public static func hash(
        _ trace: [DVSMTraceEvent]
    ) -> Data {

        var accumulator = Data()

        for event in trace {

            accumulator.append(
                withUnsafeBytes(of: event.tick.bigEndian) {
                    Data($0)
                }
            )

            accumulator.append(event.preStateHash)
            accumulator.append(event.postStateHash)
        }

        return DVSMHashing.sha256(accumulator)
    }
}

