public enum DVSMDeviationAnalyzer {

    // ---------------------------------------------
    // COMPARE TRACE AGAINST CANONICAL
    // ---------------------------------------------

    public static func deviationScore(
        localTrace: Data,
        canonicalTrace: Data
    ) -> Double {

        let mismatchCount =
            zip(localTrace, canonicalTrace)
                .filter { $0 != $1 }
                .count

        let total = max(localTrace.count, 1)

        return Double(mismatchCount) / Double(total)
    }
}

