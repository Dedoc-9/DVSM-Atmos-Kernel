import Foundation

// =====================================================
// MARK: - DIVERGENCE DEBUGGER
// =====================================================

public enum DVSMDivergenceDebugger {

    // -------------------------------------------------
    // MAIN ENTRYPOINT
    // -------------------------------------------------

    public static func compare(
        expected: DVSMReplayResult,
        observed: DVSMReplayResult
    ) -> DVSMDivergenceReport {

        // -------------------------------------------------
        // STEP 1: TRACE LENGTH CHECK
        // -------------------------------------------------

        guard expected.trace.count == observed.trace.count else {

            return DVSMDivergenceReport(
                status: .traceLengthMismatch,
                mismatchTick: nil,
                mismatchByteOffset: nil,
                expectedByte: nil,
                observedByte: nil,
                expectedBits: nil,
                observedBits: nil,
                summary: "Trace lengths differ"
            )
        }

        // -------------------------------------------------
        // STEP 2: FIND FIRST DIVERGENT EVENT
        // -------------------------------------------------

        for index in 0..<expected.trace.count {

            let lhs = expected.trace[index]
            let rhs = observed.trace[index]

            if lhs.postStateHash != rhs.postStateHash {

                // Reconstruct deterministic page snapshots
                let expectedPage = reconstructPage(
                    replay: expected,
                    upTo: index
                )

                let observedPage = reconstructPage(
                    replay: observed,
                    upTo: index
                )

                return compareMemoryPages(
                    expected: expectedPage,
                    observed: observedPage,
                    tick: UInt64(index)
                )
            }
        }

        // -------------------------------------------------
        // NO DIVERGENCE
        // -------------------------------------------------

        return DVSMDivergenceReport(
            status: .identical,
            mismatchTick: nil,
            mismatchByteOffset: nil,
            expectedByte: nil,
            observedByte: nil,
            expectedBits: nil,
            observedBits: nil,
            summary: "Replay traces are identical"
        )
    }

    // -------------------------------------------------
    // RECONSTRUCT MEMORY PAGE
    // -------------------------------------------------

    private static func reconstructPage(
        replay: DVSMReplayResult,
        upTo tick: Int
    ) -> Data {

        var memory = replay.finalMemory

        // Simplified placeholder:
        // In production:
        // - reconstruct incrementally
        // - snapshot pages
        // - support multi-page replay

        if replay.trace.indices.contains(tick) {

            let event = replay.trace[tick]

            memory.append(event.preStateHash)
            memory.append(event.postStateHash)
        }

        return memory
    }

    // -------------------------------------------------
    // PAGE COMPARISON
    // -------------------------------------------------

    private static func compareMemoryPages(
        expected: Data,
        observed: Data,
        tick: UInt64
    ) -> DVSMDivergenceReport {

        let minimum = min(expected.count, observed.count)

        for offset in 0..<minimum {

            let lhs = expected[offset]
            let rhs = observed[offset]

            if lhs != rhs {

                return DVSMDivergenceReport(
                    status: .diverged,
                    mismatchTick: tick,
                    mismatchByteOffset: offset,
                    expectedByte: lhs,
                    observedByte: rhs,
                    expectedBits: binary(lhs),
                    observedBits: binary(rhs),
                    summary: buildSummary(
                        tick: tick,
                        offset: offset,
                        lhs: lhs,
                        rhs: rhs
                    )
                )
            }
        }

        return DVSMDivergenceReport(
            status: .unknownMismatch,
            mismatchTick: tick,
            mismatchByteOffset: nil,
            expectedByte: nil,
            observedByte: nil,
            expectedBits: nil,
            observedBits: nil,
            summary: "Hash mismatch detected but byte diff unresolved"
        )
    }

    // -------------------------------------------------
    // BITSTRING CONVERSION
    // -------------------------------------------------

    private static func binary(_ byte: UInt8) -> String {

        String(byte, radix: 2)
            .leftPadding(toLength: 8, withPad: "0")
    }

    // -------------------------------------------------
    // HUMAN SUMMARY
    // -------------------------------------------------

    private static func buildSummary(
        tick: UInt64,
        offset: Int,
        lhs: UInt8,
        rhs: UInt8
    ) -> String {

        """
        Divergence detected:
        tick=\(tick)
        byte_offset=0x\(String(offset, radix: 16))
        expected=0x\(String(lhs, radix: 16))
        observed=0x\(String(rhs, radix: 16))
        """
    }
}

