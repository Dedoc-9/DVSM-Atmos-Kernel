public enum DVSMRealityCompressionKernel {

    /**
     # COMPRESS

     Reduces full timeline into deterministic delta-chain.
     */
    public static func compress(
        timeline: [DVSTimelineEvent],
        rootHash: Data
    ) -> DVSMCompressedReality {

        let deltas = timeline.map { $0.canonicalStateHash }

        let spatial = timeline.map { $0.spatialAnchor }

        let entropy = SHA256.hash(data: Data(deltas.flatMap { $0 })).data

        return DVSMCompressedReality(
            rootStateHash: rootHash,
            deltaChain: deltas,
            spatialIndex: spatial,
            entropySignature: entropy
        )
    }

    /**
     # DECOMPRESS

     Fully reconstructs timeline deterministically.
     */
    public static func decompress(
        _ compressed: DVSMCompressedReality
    ) -> [DVSTimelineEvent] {

        var events: [DVSTimelineEvent] = []

        for (i, delta) in compressed.deltaChain.enumerated() {
            events.append(
                DVSTimelineEvent(
                    tick: UInt64(i),
                    canonicalStateHash: delta,
                    spatialAnchor: compressed.spatialIndex[i]
                )
            )
        }

        return events
    }
