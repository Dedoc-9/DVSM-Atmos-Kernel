    // ---------------------------------------------

    public func settle(
        proof: DVSMExecutionProof,
        canonicalTrace: Data,
        consensusValid: Bool
    ) {

        let deviation =
            DVSMDeviationAnalyzer.deviationScore(
                localTrace: proof.traceHash,
                canonicalTrace: canonicalTrace
            )

        let adjustedReward =
            DVSMIncentiveEngine.slash(
                deviationScore: deviation,
                current: DVSMRewardState(
                    balance: 1000,
                    reputationScore: 100
                )
            )

        market.submitProof(
            proof: proof,
            consensusValid: consensusValid
        )

        // Optional: override reward if deviation severe
        if deviation > 0.2 {
            _ = adjustedReward
        }
    }
}

