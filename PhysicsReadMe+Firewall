        let conflicts = detectConflicts(a: a, b: b)

        // deterministic rule: lower UUID wins canonical identity
        let canonical = a.worldlineID.uuidString < b.worldlineID.uuidString ? a : b

        // resolution hash = XOR-style deterministic combination
        let mergedHash = zip(a.headLedgerHash, b.headLedgerHash).map { $0 ^ $1 }

        let merged = DVSMWorldline(
            worldlineID: canonical.worldlineID,
            parentWorldline: canonical.parentWorldline,
            genesisHash: canonical.genesisHash,
            headLedgerHash: Data(mergedHash)
        )

        return DVSMWorldlineMergeResult(
            mergedWorldline: merged,
            conflictTicks: conflicts,
            resolutionHash: Data(mergedHash)
        )
    }
