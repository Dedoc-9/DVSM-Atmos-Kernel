public enum DVSMIncentiveEngine {

    // ---------------------------------------------
    // REWARD FOR CORRECT EXECUTION
    // ---------------------------------------------

    public static func reward(
        proof: DVSMExecutionProof,
        isConsensusValid: Bool,
        baseReward: Int64
    ) -> DVSMRewardState {

        guard isConsensusValid else {

            // SLASHING CONDITION
            return DVSMRewardState(
                balance: -baseReward,
                reputationScore: -100
            )
        }

        let computePenalty =
            Int64(proof.computeUnits / 1000)

        let reward = baseReward - computePenalty

        return DVSMRewardState(
            balance: reward,
            reputationScore: 10
        )
    }

    // ---------------------------------------------
    // SLASHING FOR DEVIATION
    // ---------------------------------------------

    public static func slash(
        deviationScore: Double,
        current: DVSMRewardState
    ) -> DVSMRewardState {

        let penalty = Int64(deviationScore * 100)

        return DVSMRewardState(
            balance: current.balance - penalty,
            reputationScore: current.reputationScore - 50
        )
    }
}

