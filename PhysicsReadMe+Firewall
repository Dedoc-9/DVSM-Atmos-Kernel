 A logic system is represented as a directed acyclic graph of gates.
 Each gate is a deterministic transformation over binary inputs.

 This enables:
 - Replayability
 - Structural verification
 - Cross-substrate determinism
 */

// MARK: - CORE SIGNAL TYPE

public enum DVSMBit: UInt8 {
    case zero = 0
    case one = 1
}

// MARK: - GATE TYPES

public enum DVSMGateType {
    case and
    case or
    case xor
    case not
}

// MARK: - LOGIC GATE NODE

public struct DVSMGateNode {

    public let id: UInt64
    public let type: DVSMGateType

    /// Input dependencies (edges in DAG)
    public let inputs: [UInt64]

    /// Deterministic evaluation result cache (optional)
    public var cachedOutput: DVSMBit?
}

// MARK: - LOGIC GRAPH

public final class DVSMLogicGraph {

    private var nodes: [UInt64: DVSMGateNode] = [:]

    public init(nodes: [DVSMGateNode]) {
        for node in nodes {
            self.nodes[node.id] = node
        }
    }

    // MARK: - EXECUTION ENGINE

    public func evaluate(outputNode: UInt64, inputs: [UInt64: DVSMBit]) -> DVSMBit {
        return evaluateNode(outputNode, inputs: inputs, memo: [:])
    }

    private func evaluateNode(
        _ id: UInt64,
        inputs: [UInt64: DVSMBit],
        memo: inout [UInt64: DVSMBit]
    ) -> DVSMBit {

        if let cached = memo[id] {
            return cached
        }

        guard let node = nodes[id] else {
            fatalError("Undefined gate node: \(id)")
        }

        // Leaf input node
        if node.inputs.isEmpty {
            let value = inputs[id] ?? .zero
            memo[id] = value
            return value
        }

        let resolvedInputs = node.inputs.map {
            evaluateNode($0, inputs: inputs, memo: &memo)
        }

        let result = applyGate(node.type, resolvedInputs)
        memo[id] = result
        return result
    }

    // MARK: - GATE LOGIC

    private func applyGate(_ type: DVSMGateType, _ inputs: [DVSMBit]) -> DVSMBit {
        switch type {

        case .and:
            return inputs.contains(.zero) ? .zero : .one

        case .or:
            return inputs.contains(.one) ? .one : .zero

        case .xor:
            let ones = inputs.filter { $0 == .one }.count
            return (ones % 2 == 0) ? .zero : .one

        case .not:
            return inputs.first == .one ? .zero : .one
        }
    }
}

// MARK: - STRUCTURAL HASHING (REPLAY INTEGRITY)

public enum DVSMLogicHasher {

    public static func hash(graph: DVSMLogicGraph) -> Data {
        var hasher = SHA256()

        // Deterministic ordering assumption (IDs sorted externally)
