import Foundation

// =====================================================
// DVSM CONVERGENCE CONTROL PLANE
// =====================================================
// PURPOSE:
// Actively manages how quickly and under what rules
// distributed nodes converge toward canonical state.
// =====================================================

// MARK: - CONVERGENCE STATE MODEL

public struct DVSMConvergenceState {
    public var driftIndex: Double          // divergence pressure in system
    public var convergenceRate: Double      // how fast system aligns
    public var trustEntropy: Double        // instability in trust distribution
}

// =====================================================
// CONTROL PLANE ENGINE
// =====================================================

public enum DVSMConvergenceControlPlane {

    // -------------------------------------------------
    // DRIFT COMPUTATION
    // -------------------------------------------------

    public static func computeDrift(
        divergenceTicks: UInt64,
        totalNodes: Int
    ) -> Double {

        guard totalNodes > 0 else { return 1.0 }

        return Double(divergenceTicks) / Double(totalNodes * 100)
    }

    // -------------------------------------------------
    // TRUST ENTROPY MODEL
    // -------------------------------------------------

    public static func computeTrustEntropy(
        reputations: [Int64]
    ) -> Double {

        guard !reputations.isEmpty else { return 1.0 }

        let mean = reputations.reduce(0, +) / Int64(reputations.count)

        let variance = reputations
            .map { Double($0 - mean) * Double($0 - mean) }
            .reduce(0, +) / Double(reputations.count)

        return variance / 1_000_000.0
    }

    // -------------------------------------------------
    // CONVERGENCE RATE ADJUSTMENT
    // -------------------------------------------------

    public static func adjustConvergenceRate(
        state: DVSMConvergenceState
    ) -> Double {

        // High drift → slow convergence (safety)
        // Low drift + low entropy → accelerate convergence

        let safetyFactor = max(0.1, 1.0 - state.driftIndex)
        let trustFactor  = max(0.1, 1.0 - state.trustEntropy)

        return safetyFactor * trustFactor
    }

    // -------------------------------------------------
    // CONTROL DECISION ENGINE
    // -------------------------------------------------

    public static func evaluate(
        divergenceTicks: UInt64,
        nodeReputations: [Int64],
        totalNodes: Int
    ) -> DVSMConvergenceState {

        let drift = computeDrift(
            divergenceTicks: divergenceTicks,
            totalNodes: totalNodes
        )

        let entropy = computeTrustEntropy(reputations: nodeReputations)

        let state = DVSMConvergenceState(
            driftIndex: drift,
            convergenceRate: 0.0,
            trustEntropy: entropy
        )

        var mutableState = state
        mutableState.convergenceRate = adjustConvergenceRate(state: state)

        return mutableState
    }
}

// =====================================================
// GOVERNANCE HOOK (CONNECTS TO YOUR SYSTEM)
// =====================================================

public enum DVSMConvergenceGovernor {

    public static func apply(
        state: DVSMConvergenceState,
        ledger: DVSMTraceLedger
    ) {

        // If drift is too high → system should slow auto-healing
        if state.driftIndex > 0.7 {
            print("⚠️ High drift detected → reducing convergence aggressiveness")
        }

        // If trust is unstable → prioritize constitution enforcement
        if state.trustEntropy > 0.5 {
