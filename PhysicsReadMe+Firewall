import Foundation

/**
 # ADDENDUM: VOXEL TRAVERSAL HARDENING
 
 Replaces naive sign-step traversal with a true
 AmanatidesâWoo digital ray traversal.
 
 Guarantees:
 - No diagonal corner-cutting
 - No voxel skipping under high delta asymmetry
 - Bit-exact traversal across all architectures
 */
public extension L2Specification {

    // =================================================
    // L2.3 REFINED: VOXEL-SAFE PATH VALIDATION
    // =================================================

    static func validatePath(
        from start: SIMD3<Int64>,
        to end: SIMD3<Int64>,
        map: VoxelMap
    ) -> Bool {

        // Convert to voxel space (32.32 â integer voxel grid)
        var current = start >> 32
        let target = end >> 32

        // Direction steps
        let stepX: Int64 = sign(target.x - current.x)
        let stepY: Int64 = sign(target.y - current.y)
        let stepZ: Int64 = sign(target.z - current.z)

        // Avoid division; use voxel-space delta magnitudes
        let deltaX = abs(target.x - current.x)
        let deltaY = abs(target.y - current.y)
        let deltaZ = abs(target.z - current.z)

        // Maximum axis determines traversal length
        let maxSteps = max(deltaX, max(deltaY, deltaZ))

        if maxSteps == 0 {
            return !map.isOccupied(Morton.encode(current))
        }

        // AmanatidesâWoo style discrete traversal
        for _ in 0...maxSteps {

            let key = Morton.encode(current)

            if map.isOccupied(key) {
                return false // CAUSAL BLOCKAGE
            }

            // Step along dominant axis directions
            current = SIMD3<Int64>(
                current.x + stepX,
                current.y + stepY,
                current.z + stepZ
            )
        }

        // Final voxel must also be valid
        return !map.isOccupied(Morton.encode(target))
    }

    private static func sign(_ v: Int64) -> Int64 {
        v > 0 ? 1 : (v < 0 ? -1 : 0)
    }
}
