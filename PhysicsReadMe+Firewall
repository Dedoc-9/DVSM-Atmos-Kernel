// =====================================================
// DVSM_L1_1_2_SUBSTRATE_INTERFACE.rs
// VERSION: WASM-METABOLISM-V1
// ROLE:
// Canonical Rust/WASM substrate interface.
//
// PURPOSE:
// 1. Define stable WASM entrypoints.
// 2. Operate directly on canonical memory layout.
// 3. Mutate deterministic substrate state.
// 4. Support replay + trace equivalence.
// 5. Become the executable metabolism of DVSM.
// =====================================================

#![no_std]

use core::slice;

// =====================================================
// MEMORY CONSTANTS
// =====================================================

const PAGE_SIZE: usize = 64 * 1024;

// -----------------------------------------------------
// HEADER REGION
// -----------------------------------------------------

const ENTITY_X_OFFSET: usize      = 0x0010;
const ENTITY_Y_OFFSET: usize      = 0x0018;

const VELOCITY_X_OFFSET: usize    = 0x0020;
const VELOCITY_Y_OFFSET: usize    = 0x0028;

const MORPHISM_SEED_OFFSET: usize = 0x0030;

const HASH_OFFSET: usize          = 0x0040;

// -----------------------------------------------------
// MOTION REGION
// -----------------------------------------------------

const MOTION_REGION_START: usize  = 0x1000;

// =====================================================
// LINEAR MEMORY
// =====================================================

#[link_section = ".memory"]
static mut MEMORY: [u8; PAGE_SIZE] = [0; PAGE_SIZE];

// =====================================================
// INTERNAL MEMORY HELPERS
// =====================================================

fn read_i64(offset: usize) -> i64 {
    unsafe {
        let bytes = &MEMORY[offset..offset + 8];
        i64::from_be_bytes(bytes.try_into().unwrap())
    }
}

fn write_i64(offset: usize, value: i64) {
    unsafe {
        MEMORY[offset..offset + 8]
            .copy_from_slice(&value.to_be_bytes());
    }
}

fn read_u64(offset: usize) -> u64 {
    unsafe {
        let bytes = &MEMORY[offset..offset + 8];
        u64::from_be_bytes(bytes.try_into().unwrap())
    }
}

fn write_u64(offset: usize, value: u64) {
    unsafe {
        MEMORY[offset..offset + 8]
            .copy_from_slice(&value.to_be_bytes());
    }
}

// =====================================================
// HASH EVOLUTION (PLACEHOLDER DETERMINISTIC HASH)
// =====================================================

fn evolve_hash() {

    let x = read_i64(ENTITY_X_OFFSET) as u64;
    let y = read_i64(ENTITY_Y_OFFSET) as u64;

    let seed = read_u64(MORPHISM_SEED_OFFSET);

    let hash =
        x.rotate_left(13) ^
        y.rotate_right(7) ^
        seed.rotate_left(29);

    write_u64(HASH_OFFSET, hash);
}

// =====================================================
// ENTRYPOINT: INIT
// =====================================================

#[no_mangle]
pub extern "C" fn dvsm_init(seed: u64) {

    // RESET HEADER REGION

    write_i64(ENTITY_X_OFFSET, 0);
    write_i64(ENTITY_Y_OFFSET, 0);

    write_i64(VELOCITY_X_OFFSET, 0);
    write_i64(VELOCITY_Y_OFFSET, 0);

    write_u64(MORPHISM_SEED_OFFSET, seed);

    evolve_hash();
}

// =====================================================
// ENTRYPOINT: PUSH MOTION
// =====================================================

#[no_mangle]
pub extern "C" fn dvsm_push_motion(x: i64, y: i64) {

    // WRITE TO MOTION REGION

    write_i64(MOTION_REGION_START + 0x00, x);
    write_i64(MOTION_REGION_START + 0x08, y);

    // UPDATE VELOCITY HEADER

    write_i64(VELOCITY_X_OFFSET, x);
    write_i64(VELOCITY_Y_OFFSET, y);
}

// =====================================================
// ENTRYPOINT: TICK
// =====================================================

#[no_mangle]
