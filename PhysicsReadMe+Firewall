    public init(nodeID: Data, role: DVSMNodeRole) {
        self.nodeID = nodeID
        self.role = role
    }

    // =====================================================
    // RECEIVE PROOF (ENTRY POINT)
    // =====================================================
    public func receive(_ message: DVSMProofMessage) -> Bool {

        // 1. Fork resolution
        guard let fork = forks[message.forkID] else {
            return reject(reason: .unknownFork)
        }

        // 2. Proof validation (no replay required)
        guard verifyProof(message.proof, against: fork) else {
            return reject(reason: .invalidProof)
        }

        // 3. Fork advancement
        advanceFork(forkID: message.forkID, proof: message.proof)

        return true
    }

    // =====================================================
    // PROOF VALIDATION CORE
    // =====================================================
    private func verifyProof(_ proof: DVSMCausalProof, against fork: DVSMFork) -> Bool {

        // A. Replay guard (idempotency)
        if proofCache.contains(proof.proofHash) {
            return true
        }

        // B. Genesis binding check
        guard fork.genesisHash == DVSMGenesisAnchor.schemaHash else {
            return false
        }

        // C. Structural integrity (fast reject path)
        let recomputed = DVSMCausalProofEngine.generate(
            sequence: proof.sequence,
            input: proof.inputHash,
            stateHash: proof.stateHash,
            capabilities: [], // capabilities derived in full verifier tier
            history: DVSMHistoryClass(
                ledgerFinalityHash: proof.inputHash,
                spatialEquivalenceAnchor: 0
            ),
            trust: Double(proof.trustTick) / 1_000_000.0
        )

        // D. Proof hash must match exactly
        guard recomputed.proofHash == proof.proofHash else {
            return false
        }

        proofCache.insert(proof.proofHash)
        return true
    }

    // =====================================================
    // FORK ADVANCEMENT (NO GLOBAL LOCKING)
    // =====================================================
    private func advanceFork(forkID: Data, proof: DVSMCausalProof) {

        guard var fork = forks[forkID] else { return }

        fork.height += 1
        fork.headProofHash = proof.proofHash

        forks[forkID] = fork
    }

    // =====================================================
    // FORK CREATION (DIVERGENCE HANDLING)
    // =====================================================
