    case shift(bits: UInt8)
    case hash
}

// =====================================================
// MARK: - MEMORY ENGINE
// =====================================================

public enum DVSMMemoryEngine {

    public static func apply(
        memory: Data,
        op: DVSMMemoryOp
    ) -> Data {

        switch op {

        case .identity:
            return memory

        case .add(let delta):
            return deterministicAdd(memory, delta)

        case .xor(let mask):
            return deterministicXOR(memory, mask)

        case .shift(let bits):
            return deterministicShift(memory, bits)

        case .hash:
            return DVSMHashing.sha256(memory)
        }
    }

    // -------------------------------------------------
    // DETERMINISTIC TRANSFORMS
    // -------------------------------------------------

    private static func deterministicAdd(
        _ memory: Data,
        _ delta: Int64
    ) -> Data {

        var output = memory

        if output.count >= 8 {

            let current = output.withUnsafeBytes {
                $0.load(as: Int64.self)
            }

            let updated = current &+ delta

            output.replaceSubrange(
                0..<8,
                with: withUnsafeBytes(of: updated.bigEndian) {
                    Data($0)
                }
            )
        }

        return output
    }

    private static func deterministicXOR(
        _ memory: Data,
        _ mask: UInt64
    ) -> Data {

        var output = memory

        if output.count >= 8 {

            let current = output.withUnsafeBytes {
                $0.load(as: UInt64.self)
            }

            let updated = current ^ mask

            output.replaceSubrange(
                0..<8,
                with: withUnsafeBytes(of: updated.bigEndian) {
                    Data($0)
                }
            )
        }

        return output
    }

    private static func deterministicShift(
        _ memory: Data,
        _ bits: UInt8
    ) -> Data {

        var output = memory

        if output.count >= 8 {

            let current = output.withUnsafeBytes {
                $0.load(as: UInt64.self)
            }

            let updated = current << bits

            output.replaceSubrange(
                0..<8,
                with: withUnsafeBytes(of: updated.bigEndian) {
                    Data($0)
                }
            )
        }

        return output
    }
}
