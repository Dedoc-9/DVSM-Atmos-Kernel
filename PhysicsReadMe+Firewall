#![no_std]

use core::convert::TryInto;

// =====================================================
// MEMORY CONSTANTS
// =====================================================

const PAGE_SIZE: usize = 64 * 1024;

// -----------------------------------------------------
// HEADER REGION
// -----------------------------------------------------

const ENTITY_X_OFFSET: usize      = 0x0010;
const ENTITY_Y_OFFSET: usize      = 0x0018;

const VELOCITY_X_OFFSET: usize    = 0x0020;
const VELOCITY_Y_OFFSET: usize    = 0x0028;

const MORPHISM_SEED_OFFSET: usize = 0x0030;

const STATE_HASH_OFFSET: usize    = 0x0040;

// -----------------------------------------------------
// VOXEL GRID REGION
// -----------------------------------------------------

const VOXEL_GRID_START: usize     = 0x4000;
const VOXEL_GRID_WIDTH: usize     = 64;
const VOXEL_GRID_HEIGHT: usize    = 64;

// =====================================================
// LINEAR MEMORY
// =====================================================

#[link_section = ".memory"]
static mut MEMORY: [u8; PAGE_SIZE] = [0; PAGE_SIZE];

// =====================================================
// MEMORY ACCESS HELPERS
// =====================================================

fn read_i64(offset: usize) -> i64 {

    unsafe {
        let bytes = &MEMORY[offset..offset + 8];

        i64::from_be_bytes(
            bytes.try_into().unwrap()
        )
    }
}

fn write_i64(offset: usize, value: i64) {

    unsafe {

        MEMORY[offset..offset + 8]
            .copy_from_slice(
                &value.to_be_bytes()
            );
    }
}

fn read_u64(offset: usize) -> u64 {

    unsafe {

        let bytes = &MEMORY[offset..offset + 8];

        u64::from_be_bytes(
            bytes.try_into().unwrap()
        )
    }
}

fn write_u64(offset: usize, value: u64) {

    unsafe {

        MEMORY[offset..offset + 8]
            .copy_from_slice(
                &value.to_be_bytes()
            );
    }
}

// =====================================================
// VOXEL ACCESS
// =====================================================

fn voxel_index(x: i64, y: i64) -> Option<usize> {

    if x < 0 || y < 0 {
        return None;
    }

    let x = x as usize;
    let y = y as usize;

    if x >= VOXEL_GRID_WIDTH ||
       y >= VOXEL_GRID_HEIGHT {
        return None;
    }

    Some(
        VOXEL_GRID_START +
        (y * VOXEL_GRID_WIDTH) +
        x
    )
}

fn voxel_is_solid(x: i64, y: i64) -> bool {

    match voxel_index(x, y) {

        Some(index) => unsafe {
            MEMORY[index] != 0
        },

        None => true // outside bounds = solid
    }
}

// =====================================================
// HASH EVOLUTION
// =====================================================

fn evolve_state_hash() {

    let x = read_i64(ENTITY_X_OFFSET) as u64;

    let y = read_i64(ENTITY_Y_OFFSET) as u64;

    let vx = read_i64(VELOCITY_X_OFFSET) as u64;

    let vy = read_i64(VELOCITY_Y_OFFSET) as u64;

    let seed = read_u64(MORPHISM_SEED_OFFSET);

    // -------------------------------------------------
    // DETERMINISTIC MORPHISM HASH
    // -------------------------------------------------

    let hash =
        x.rotate_left(11) ^
        y.rotate_right(5) ^
        vx.rotate_left(17) ^
        vy.rotate_right(13) ^
        seed.rotate_left(29);

    write_u64(STATE_HASH_OFFSET, hash);
}

