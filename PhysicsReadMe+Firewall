        let newForkID = SHA256.hash(data: proof.proofHash).data

        let fork = DVSMFork(
            forkID: newForkID,
            parentForkID: parent.forkID,
            genesisHash: parent.genesisHash,
            headProofHash: proof.proofHash,
            height: parent.height + 1
        )

        forks[newForkID] = fork
        return fork
    }

    // =====================================================
    // FAILURE HANDLING
    // =====================================================
    private func reject(reason: DVSMForkError) -> Bool {
        return false
    }
