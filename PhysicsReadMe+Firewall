        write_i64(
            ENTITY_X_OFFSET,
            proposed_x
        );

        write_i64(
            ENTITY_Y_OFFSET,
            proposed_y
        );
    }

    // -------------------------------------------------
    // EVOLVE HASH
    // -------------------------------------------------

    evolve_state_hash();
}

