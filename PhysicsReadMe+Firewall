    // -------------------------------------------------

    public func evaluateHealth(currentTick: UInt64, timeout: UInt64 = 5) {
        for (id, node) in nodes {

            let delta = currentTick - node.lastHeartbeatTick

            if delta > timeout {
                var updated = node
                updated.state = .degraded
                nodes[id] = updated
