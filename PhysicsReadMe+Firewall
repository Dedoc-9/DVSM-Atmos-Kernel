    // -------------------------------------------------

    public func step(
        state: inout State,
        proposedDelta: DVSMLawDelta,
        incomingMeshes: [DVSMMesh]
    ) {

        // 1. L24: Adversarial filtering + normalization
        let cleanedMeshes = DVSMMeshGuardian.process(
            reference: incomingMeshes.first!,
            candidates: incomingMeshes,
            topology: DVMSelfHealingTopology()
