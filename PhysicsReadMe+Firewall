import Foundation

// =====================================================
// AUTO-HEALING CONSENSUS REPAIR ENGINE
// =====================================================
// PURPOSE:
// Detect divergence in trace ledger and repair state
// using deterministic, replayable consensus rules.
// =====================================================

// MARK: - REPAIR STRATEGY

public enum DVSMRepairStrategy {
    case majorityHash        // most frequent runtime output wins
    case rustAuthority       // Rust is canonical truth kernel
    case earliestValidTick   // first valid state is authoritative
}

// =====================================================
// CONSENSUS REPAIR ENGINE
// =====================================================

public enum DVSMAutoHealingEngine {

    // -------------------------------------------------
    // MAIN REPAIR FUNCTION
    // -------------------------------------------------

    public static func repair(
        ledger: DVSMTraceLedger,
        strategy: DVSMRepairStrategy
    ) -> DVSMRepairResult {

        let grouped = Dictionary(grouping: ledger.fullTrace(), by: { $0.tick })

        var repairs: [DVSMRepairAction] = []

        for tick in grouped.keys.sorted() {

            let events = grouped[tick]!
            let hashes = Dictionary(grouping: events, by: { $0.outputHash })

            // -------------------------------------------------
            // NO DIVERGENCE → skip
            // -------------------------------------------------

            if hashes.count <= 1 { continue }

            // -------------------------------------------------
            // DIVERGENCE DETECTED → RESOLVE
            // -------------------------------------------------

            let canonicalHash: Data

            switch strategy {

            case .majorityHash:
                canonicalHash = hashes
                    .max(by: { $0.value.count < $1.value.count })!
                    .key

            case .rustAuthority:
                canonicalHash = events
                    .first(where: { $0.runtime == .rust })!
                    .outputHash

            case .earliestValidTick:
                canonicalHash = events
                    .sorted(by: { $0.tick < $1.tick })
                    .first!
                    .outputHash
            }

            // -------------------------------------------------
            // APPLY REPAIR (DETERMINISTIC PATCH EVENT)
            // -------------------------------------------------

            let repair = DVSMRepairAction(
                tick: tick,
                resolvedHash: canonicalHash
            )

            repairs.append(repair)
        }

        return DVSMRepairResult(
            repairedTicks: repairs,
            success: true
        )
    }
}

// =====================================================
// REPAIR EVENTS (IMMUTABLE CAUSAL RECORD)
// =====================================================

public struct DVSMRepairAction {
    public let tick: UInt64
    public let resolvedHash: Data
}

public struct DVSMRepairResult {
    public let repairedTicks: [DVSMRepairAction]
    public let success: Bool
}

