// =================================================
// MARK: - FULL WORLDLINE REPLAY (L17 ENABLED)
// =================================================

public func replay(worldline: UUID) -> [DVSMCausalEvent] {

    guard let headHash = headPointers[worldline],
          let head = events[headHash] else {
        return []
    }

    var chain: [DVSMCausalEvent] = []
    var current: DVSMCausalEvent? = head

    while let event = current {
        chain.append(event)

        guard let parentHash = event.parentHash,
              let parent = events[parentHash] else {
            break
        }

        current = parent
    }

    return chain.reversed()
}

