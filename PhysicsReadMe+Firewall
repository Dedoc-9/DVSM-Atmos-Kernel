// =====================================================

private extension DVSMConcurrencyProof {

    static func parallelSpeculation(
        _ pulses: [DVSMRawPulse],
        threadCount: Int
    ) -> [DVSMSpeculativeResult] {

        let lock = NSLock()

        var results:
            [DVSMSpeculativeResult] = []

        DispatchQueue.concurrentPerform(
            iterations: pulses.count
        ) { index in

            let pulse = pulses[index]

            let delta =
                deterministicTransition(pulse)

            let result =
                DVSMSpeculativeResult(
                    key: DVSMCanonicalKey(
                        entityID: pulse.entityID,
                        sequence: pulse.sequence
                    ),
                    stateDelta: delta,
                    localHash: seal(
                        canonicalBytes(delta)
                    )
                )

            lock.lock()
            results.append(result)
            lock.unlock()
        }

        return results
    }
}

// =====================================================
// MARK: - DETERMINISTIC TRANSITION
// =====================================================

private extension DVSMConcurrencyProof {

    static func deterministicTransition(
        _ pulse: DVSMRawPulse
    ) -> DVSMStateDelta {

        // ---------------------------------------------
        // PURE FUNCTION
        // ---------------------------------------------
        //
        // IMPORTANT:
        // NO SHARED STATE ACCESS
        // NO GLOBAL MEMORY MUTATION
        // NO ORDER DEPENDENCY
        //
        // ---------------------------------------------

        let nextX = pulse.velocityX
        let nextY = pulse.velocityY

        let admissible =
            abs(nextX) < 1_000_000 &&
            abs(nextY) < 1_000_000

        return DVSMStateDelta(
            entityID: pulse.entityID,
            nextX: admissible ? nextX : 0,
            nextY: admissible ? nextY : 0,
            committed: admissible
        )
    }
}

// =====================================================
// MARK: - CANONICAL ORDERING
// =====================================================

private extension DVSMConcurrencyProof {

    static func canonicalOrder(
        _ pulses: [DVSMRawPulse]
    ) -> [DVSMRawPulse] {

        pulses.sorted {

            if $0.entityID != $1.entityID {
                return $0.entityID < $1.entityID
            }

            return $0.sequence < $1.sequence
        }
    }
}

// =====================================================
// MARK: - CANONICAL SERIALIZATION
// =====================================================

private extension DVSMConcurrencyProof {

    static func canonicalBytes(
        _ delta: DVSMStateDelta
    ) -> Data {

        var data = Data()

        appendUInt64(
            delta.entityID,
            into: &data
        )

        appendInt64(
            delta.nextX,
            into: &data
        )

        appendInt64(
            delta.nextY,
            into: &data
        )

        appendUInt64(
            delta.committed ? 1 : 0,
            into: &data
        )

        return data
    }
}

// =====================================================
// MARK: - CRYPTO
// =====================================================

private extension DVSMConcurrencyProof {

    static func seal(
        _ data: Data
    ) -> Data {

        Data(
            SHA256.hash(data: data)
        )
    }
}

// =====================================================
// MARK: - FIXED-WIDTH SERIALIZATION
// =====================================================

private extension DVSMConcurrencyProof {

    static func appendUInt64(
        _ value: UInt64,
        into data: inout Data
    ) {

        var big = value.bigEndian

        withUnsafeBytes(of: &big) {
            data.append(contentsOf: $0)
        }
    }

    static func appendInt64(
        _ value: Int64,
        into data: inout Data
    ) {

        var big = value.bigEndian

        withUnsafeBytes(of: &big) {
            data.append(contentsOf: $0)
        }
    }
}

