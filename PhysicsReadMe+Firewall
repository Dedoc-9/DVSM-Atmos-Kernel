        // 3. L24.2: trust reconstruction pass
        for mesh in cleanedMeshes {
            let trust = reconstructor.trust(for: mesh.meshID)
            _ = trust // used implicitly in governance weighting
        }

        // 4. L∞ ↔ L24 governance validation
