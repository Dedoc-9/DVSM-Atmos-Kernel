 Resolves conflicts between multiple *valid canonical timelines*
 produced by different nodes or partitions of reality.

 CORE IDEA:
 There is no single truth until convergence.
 Truth is selected via weighted manifold agreement.
 */

public struct DVSMCanonicalFork {
    public let timeline: [DVSTimelineEvent]
    public let trustWeight: Double
    public let originNode: UUID
}

// MARK: - FORK RESOLUTION ENGINE

public enum DVSMForkResolver {

    /**
     # RESOLVE CANONICAL REALITY

     Selects the dominant timeline across competing universes.
     */
    public static func resolve(
        forks: [DVSMCanonicalFork]
    ) -> [DVSTimelineEvent]? {

        guard !forks.isEmpty else { return nil }

        // 1. PRIMARY: trust-weighted dominance
        let sorted = forks.sorted { a, b in
            if a.trustWeight != b.trustWeight {
                return a.trustWeight > b.trustWeight
            }

            // 2. SECONDARY: longer valid timeline wins
            if a.timeline.count != b.timeline.count {
                return a.timeline.count > b.timeline.count
            }

            // 3. FINAL: deterministic node ordering
            return a.originNode.uuidString < b.originNode.uuidString
        }

        return sorted.first?.timeline
    }

    /**
     # CONSENSUS DISTANCE METRIC

     Measures divergence between competing realities.
     */
    public static func divergence(
        a: [DVSTimelineEvent],
        b: [DVSTimelineEvent]
    ) -> Double {

        let minCount = min(a.count, b.count)
        guard minCount > 0 else { return 1.0 }

        var mismatches = 0

        for i in 0..<minCount {
            if a[i].canonicalStateHash != b[i].canonicalStateHash {
                mismatches += 1
            }
        }

        return Double(mismatches) / Double(minCount)
    }
}

