// =====================================================

#[no_mangle]
pub extern "C" fn dvsm_init(seed: u64) {

    write_i64(ENTITY_X_OFFSET, 0);
    write_i64(ENTITY_Y_OFFSET, 0);

    write_i64(VELOCITY_X_OFFSET, 0);
    write_i64(VELOCITY_Y_OFFSET, 0);

    write_u64(MORPHISM_SEED_OFFSET, seed);

    evolve_state_hash();
}

