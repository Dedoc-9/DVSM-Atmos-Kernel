        proof: DVSMExecutionProof,
        consensusValid: Bool
    ) {

        let reward = DVSMIncentiveEngine.reward(
            proof: proof,
            isConsensusValid: consensusValid,
            baseReward: 1000
        )

        ledger[proof.nodeID] = reward
    }

    // ---------------------------------------------
    // QUERY NODE STATE
    // ---------------------------------------------

    public func state(for node: Data) -> DVSMRewardState? {

        return ledger[node]
    }
}

