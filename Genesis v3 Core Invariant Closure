        replay: Data,
        execution: Data,
        epsilon: Double,
        nodes: Int,
        faulty: Int
    ) -> Bool {

        // Canonicalization layer ensures deterministic comparability
        let cReplay = DVSMCanonicalizer.canonicalize(replay)
        let cExec   = DVSMCanonicalizer.canonicalize(execution)

        // Structural equivalence (forensic identity)
