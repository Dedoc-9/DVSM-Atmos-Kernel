// =====================================================
// MARK: - ADAPTIVE GOSSIP CONTROL (CONVERGENCE LAYER)
// =====================================================

public struct DVSMGossipControl {

    /// Dynamically adjusts gossip probability based on network entropy
    public static func adjustedProbability(
        networkSize: Int,
        messageLoad: Int
    ) -> Double {

        guard networkSize > 0 else { return 0 }

        let base = 1.0 / sqrt(Double(networkSize))
        let congestionFactor = min(Double(messageLoad) / 1000.0, 1.0)

        return max(0.1, base * (1.0 - congestionFactor))
    }
}

// =====================================================
// MARK: - ENHANCED P2P ORCHESTRATOR
// =====================================================

public final class DVSMP2POrchestratorEnhanced {

    private let nodeID: String
    private var peers: Set<String> = []
    public weak var delegate: DVSMTransportDelegate?

    // runtime adaptive gossip rate
    private var gossipProbability: Double = 0.4

    // message deduplication cache (causal safety)
    private var seenMessages: Set<Data> = []

    public init(nodeID: String) {
        self.nodeID = nodeID
    }

    // =================================================
    // PEER MANAGEMENT
    // =================================================

    public func addPeer(_ peerID: String) {
        peers.insert(peerID)
    }

    // =================================================
    // BROADCAST (GOSSIP PROPAGATION ENGINE)
    // =================================================

    public func broadcast(message: DVSMMessage) {

        // 1. Signature validation gate
        guard message.isValidSignature() else {
            print("[DVSM-P2P] REJECTED: invalid signature")
            return
        }

        // 2. Deduplication (causal safety)
        let msgHash = message.hash()
        guard !seenMessages.contains(msgHash) else {
            return
        }
        seenMessages.insert(msgHash)

        // 3. Adaptive gossip tuning
        gossipProbability = DVSMGossipControl.adjustedProbability(
            networkSize: peers.count,
            messageLoad: seenMessages.count
        )

        // 4. Select subset of peers
        let targetCount = max(1, Int(Double(peers.count) * gossipProbability))
        let targets = Array(peers.shuffled().prefix(targetCount))

        // 5. Propagate
        for peer in targets {
            send(message, to: peer)
        }
    }

    // =================================================
    // TRANSPORT LAYER (ABSTRACTED NETWORK SEND)
    // =================================================

    private func send(_ message: DVSMMessage, to peer: String) {

        // In real DVSM:
        // - QUIC stream
        // - encrypted envelope
        // - TEE-bound identity signature

        print("""
        [DVSM-P2P]
        Node: \(nodeID)
        → Gossiping state \(message.state.stateHash.prefix(6))
        → Target peer: \(peer)
        """)
    }

    // =================================================
    // INBOUND MESSAGE HANDLER
    // =================================================

    public func receive(_ message: DVSMMessage) {

        guard message.isValidSignature() else { return }

        delegate?.didReceiveMessage(message)
    }
}

