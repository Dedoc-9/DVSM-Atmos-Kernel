import Foundation

// =====================================================
// MARK: - CORE TYPES
// =====================================================

public struct EchoSpear {
    public let id: UInt64
    public let velocity: Double
    public let timestamp: UInt64
    public let position: (Int, Int)
    public let orientation: Orientation
}

public enum Orientation {
    case horizontal
    case vertical
}

// =====================================================
// MARK: - TOPOLOGICAL CELL STATES (CLOSED LATTICE)
// =====================================================

public enum NodeState {
    case empty
    case seeded
    case planted
    case frozen
    case absorbing

    /// CRITICAL FIX:
    /// Ghost resolution is NOT deletion—it is quotient absorption
    case void
}

// =====================================================
// MARK: - AZTEC MANIFOLD (QUOTIENT-BASED)
// =====================================================

public final class AztecManifold {

    public let size: Int
    public var grid: [[NodeState]]
    public var frozenMask: [[Bool]]

    public init(size: Int) {
        self.size = size
        self.grid = Array(
            repeating: Array(repeating: .empty, count: size),
            count: size
        )
        self.frozenMask = Array(
            repeating: Array(repeating: false, count: size),
            count: size
        )
    }

    // =================================================
    // MARK: GEOMETRIC SEED SET AXIOM
    // =================================================
    public func seedSetValid() -> Bool {
        let seededCount = grid.flatMap { $0 }.filter {
            $0 == .seeded || $0 == .planted || $0 == .frozen
        }.count

        return seededCount >= (size * size) / 4
    }

    // =================================================
    // MARK: VOID QUOTIENT COLLAPSE (GHOST RESOLUTION)
    // =================================================
    private func collapseVoidRegions() {

        for r in 0..<size {
            for c in 0..<size {

                guard grid[r][c] == .empty else { continue }

                let surroundedByFrozen =
                    neighbors(r, c).allSatisfy { frozenMask[$0.0][$0.1] }

                if surroundedByFrozen {
                    grid[r][c] = .void
                }
            }
        }
    }

    private func neighbors(_ r: Int, _ c: Int) -> [(Int, Int)] {
        var n: [(Int, Int)] = []
        if r > 0 { n.append((r-1,c)) }
        if r < size-1 { n.append((r+1,c)) }
        if c > 0 { n.append((r,c-1)) }
        if c < size-1 { n.append((r,c+1)) }
        return n
    }

    // =================================================
    // MARK: S_THROW (KINETIC INJECTION — ENERGY ONLY)
    // =================================================
    public func s_throw(_ spear: EchoSpear) -> Bool {

        guard spear.velocity >= 5.0 else { return false }

        let (r, c) = spear.position
        guard inBounds(r, c) else { return false }

        guard grid[r][c] == .empty else { return false }

        grid[r][c] = .seeded
        return true
    }

    // =================================================
    // MARK: S_PLANT (TOPOLOGY COMMIT — NO OVERWRITE AUTHORITY)
    // =================================================
    public func s_plant(_ spear: EchoSpear) -> Bool {

        let (r, c) = spear.position
        guard inBounds(r, c) else { return false }
        guard !frozenMask[r][c] else { return false }

        // CRITICAL FIX:
        // Velocity no longer grants overwrite authority
        // It only influences freeze probability

        switch spear.orientation {

        case .horizontal:
            guard c + 1 < size else { return false }
            guard validCell(r, c), validCell(r, c+1) else { return false }

            grid[r][c] = .planted
            grid[r][c+1] = .planted

        case .vertical:
            guard r + 1 < size else { return false }
            guard validCell(r, c), validCell(r+1, c) else { return false }

            grid[r][c] = .planted
            grid[r+1][c] = .planted
        }

        if spear.velocity > 15.0 {
            freeze(r, c)
        }

        return true
    }

    // =================================================
    // MARK: S_ECHO (ABSORBING HANDSHAKE)
    // =================================================
    public func s_echo(_ r: Int, _ c: Int, causalDepth: UInt64) -> Bool {

        guard inBounds(r, c) else { return false }
        guard frozenMask[r][c] else { return false }

        // CRITICAL FIX:
        // No global barrier — only causal monotonic ordering
        guard causalDepth >= localDepth(r, c) else { return false }

        grid[r][c] = .absorbing
        return true
    }

    // =================================================
    // MARK: ARCTIC BOUNDARY EXPANSION (WITH VOID QUOTIENT)
    // =================================================
    public func expandArcticBoundary() {

        guard seedSetValid() else { return }

        collapseVoidRegions()

        for r in 0..<size {
            for c in 0..<size {
                if grid[r][c] == .planted {
                    grid[r][c] = .frozen
                    frozenMask[r][c] = true
                }
            }
        }
    }

    // =================================================
    // MARK: FIRST PACKET CONDITION (LOCALIZED FIXED POINT)
    // =================================================
    public func firstPacketReady() -> Bool {

        let frozenCount = grid.flatMap { $0 }.filter { $0 == .frozen }.count

        return frozenCount >= (size * size) / 2
    }

    // =================================================
    // MARK: HELPERS
    // =================================================

    private func freeze(_ r: Int, _ c: Int) {
        grid[r][c] = .frozen
        frozenMask[r][c] = true
    }

    private func validCell(_ r: Int, _ c: Int) -> Bool {
        return grid[r][c] == .empty || grid[r][c] == .seeded
    }

    private func inBounds(_ r: Int, _ c: Int) -> Bool {
        return r >= 0 && c >= 0 && r < size && c < size
    }

    private func localDepth(_ r: Int, _ c: Int) -> UInt64 {
        return UInt64(r + c)
    }
}

// =====================================================
// MARK: - BOOT SEQUENCE (FINAL ENTRY POINT)
// =====================================================

public final class FirstPacketBoot {

    public let manifold: AztecManifold

    public init(size: Int) {
        self.manifold = AztecManifold(size: size)
    }

    public func executeBoot() -> Bool {

        guard manifold.seedSetValid() else { return false }

        manifold.expandArcticBoundary()

        guard manifold.firstPacketReady() else { return false }

        for r in 0..<manifold.size {
            for c in 0..<manifold.size {
                _ = manifold.s_echo(r, c, causalDepth: UInt64(r + c))
            }
        }

        return true
    }
}

