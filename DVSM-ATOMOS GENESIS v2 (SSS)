public struct DVSMMetricWeights {
    public var alpha: Double   // identity
    public var beta: Double    // causal structure
    public var gamma: Double   // entropy
}

public enum DVSMMetric {

    /// Core quotient-space metric
    public static func distH(
        _ a: DVSMStateLike,
        _ b: DVSMStateLike,
        weights: DVSMMetricWeights
    ) -> Double {

        let identity = hamming(a.identityHash, b.identityHash)
        let causal   = hamming(a.causalFingerprint, b.causalFingerprint)
        let entropy  = abs(a.causalEntropy - b.causalEntropy)

        return
            weights.alpha * identity +
            weights.beta  * causal +
            weights.gamma * entropy
    }

    private static func hamming(_ a: Data, _ b: Data) -> Double {
        let count = min(a.count, b.count)
        guard count > 0 else { return 0 }

        var diff: Double = 0
        for i in 0..<count {
            diff += Double((a[i] ^ b[i]).nonzeroBitCount)
        }
        return diff / Double(count * 8)
    }
}

