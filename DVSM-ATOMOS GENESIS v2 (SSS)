    public func equivalent(_ a: DVSMStateLike, _ b: DVSMStateLike) -> Bool {
        DVSMMetric.distH(a, b, weights: .default) < epsilon
    }
}

public extension DVSMMetricWeights {
    static let `default` = DVSMMetricWeights(
        alpha: 1.0,
        beta: 1.0,
        gamma: 1.0
    )
}

