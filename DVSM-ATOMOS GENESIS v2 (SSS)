struct ShardRegistry {
    node_to_shard: HashMap<NodeID, u64>,
    shard_load: HashMap<u64, usize>,
}

impl ShardRegistry {

    fn new() -> Self {
        Self {
            node_to_shard: HashMap::new(),
            shard_load: HashMap::new(),
        }
    }

    // dynamic shard assignment (load balancing)
    fn assign(&mut self, node: NodeID) -> u64 {

        let shard = self.shard_load
            .iter()
            .min_by_key(|(_, load)| *load)
            .map(|(s, _)| *s)
            .unwrap_or(0);

        *self.shard_load.entry(shard).or_insert(0) += 1;
        self.node_to_shard.insert(node, shard);

        shard
    }

    // migration when overloaded
    fn migrate(&mut self, node: &NodeID, new_shard: u64) {
        self.node_to_shard.insert(node.clone(), new_shard);
    }
}

