fn verify_chain(log: &Vec<SignedEvent>) -> bool {

    for i in 1..log.len() {

        let prev = &log[i - 1];
        let curr = &log[i];

        // enforce per-node monotonicity
        if prev.node == curr.node && curr.height <= prev.height {
            return false;
        }

        // enforce shard consistency
        if curr.shard != prev.shard && curr.height == prev.height {
            return false;
        }
    }

    true
}

