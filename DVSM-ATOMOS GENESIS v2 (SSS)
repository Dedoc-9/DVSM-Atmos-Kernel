type NodeID = String;

#[derive(Clone)]
struct SignedEvent {
    node: NodeID,
    shard: u64,
    height: u64,
    payload: Vec<u8>,
    hash: Vec<u8>,
}

impl SignedEvent {
    fn new(node: NodeID, shard: u64, height: u64, payload: Vec<u8>) -> Self {

        let mut hasher = Sha256::new();
        hasher.update(&node.as_bytes());
        hasher.update(&shard.to_le_bytes());
        hasher.update(&height.to_le_bytes());
        hasher.update(&payload);

        let hash = hasher.finalize().to_vec();

        Self {
            node,
            shard,
            height,
            payload,
            hash,
        }
    }
}

//////////////////////////////////////////////////////////////
// 2. BYZANTINE LOG REPLICATION ENGINE (in2 CORE)
//////////////////////////////////////////////////////////////

struct ReplicationEngine {
    log: Vec<SignedEvent>,
    seen_hashes: HashSet<Vec<u8>>,
}

impl ReplicationEngine {

    fn new() -> Self {
        Self {
            log: vec![],
            seen_hashes: HashSet::new(),
        }
    }

    // Reject forks + duplicates
    fn append(&mut self, event: SignedEvent) -> bool {

        // ---- FORK DETECTION ----
        if self.seen_hashes.contains(&event.hash) {
            return false;
        }

        // enforce monotonic per-node ordering
        if let Some(last) = self.log.last() {
            if last.node == event.node && event.height <= last.height {
                return false; // replay attack / fork
            }
        }

        self.seen_hashes.insert(event.hash.clone());
        self.log.push(event);

        true
    }

    fn head(&self) -> Option<&SignedEvent> {
        self.log.last()
    }
}

