// =====================================================

/// Eliminates concurrency jitter.
///
/// Two equivalent runtimes MUST produce:
///
///     identical canonical byte streams
///
/// regardless of:
/// - thread scheduling
/// - iteration ordering
/// - machine architecture
///
public enum DVSMCanonicalOrder {

    /// Stable deterministic sort priority:
    ///
    /// 1. clock.tick
    /// 2. cause hash
    /// 3. source hash
    /// 4. destination hash
    /// 5. proof payload hash
    ///
    public static func sort(
        _ transitions: [DVSMTransition]
    ) -> [DVSMTransition] {

        transitions.sorted {

            if $0.clock.tick != $1.clock.tick {
                return $0.clock.tick < $1.clock.tick
            }

            if $0.cause != $1.cause {
                return $0.cause.lexicographicallyPrecedes($1.cause)
            }

            if $0.from != $1.from {
                return $0.from.lexicographicallyPrecedes($1.from)
            }

            if $0.to != $1.to {
                return $0.to.lexicographicallyPrecedes($1.to)
            }

            return $0.proof.payload
                .lexicographicallyPrecedes(
                    $1.proof.payload
                )
        }
    }
}

