public struct DVSMCanonicalReplayEncoder:
    DVSMCanonicalizer {

    public init() {}

    public func canonicalize(
        _ transitions: [DVSMTransition]
    ) -> Data {

        let ordered =
            DVSMCanonicalOrder.sort(transitions)

        var data = Data()

        for t in ordered {

            data.append(t.from)
            data.append(t.to)
            data.append(t.cause)
            data.append(t.proof.payload)

            var tickLE =
                t.clock.tick.littleEndian

            withUnsafeBytes(of: &tickLE) {
                data.append(contentsOf: $0)
            }
        }

        return data
    }
}

