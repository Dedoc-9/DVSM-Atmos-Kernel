        let seedHash =
            Data(SHA256.hash(data: withUnsafeBytes(of: context.seed.bigEndian, Array.init)))

        let entropyHash =
            Data(SHA256.hash(data: context.entropy))

        let combined =
            seedHash + entropyHash

        let stateHash =
            Data(SHA256.hash(data: combined))

        return DVSMState(
            entityCount: 0,
            tick: 0,
            entropySeed: combined,
            stateHash: stateHash
        )
    }
}

