        // ---------------------------------------------
        // GATE 5: ECONOMIC VALIDATION HOOK
        // ---------------------------------------------
        if s.reject {
            DVSEconomicLayer.slash(entity: s.entityID)
        } else {
            DVSEconomicLayer.reward(entity: s.entityID)
        }

        return s
    }
}

