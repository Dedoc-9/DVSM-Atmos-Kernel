public enum DVSMGenesisEvent {

    public static func inject(
        state: inout DVSMState
    ) {

        let genesisEvent =
            Data("DVSM_GENESIS_EVENT".utf8)

        let hash =
            Data(SHA256.hash(data: genesisEvent))

        state.stateHash =
            Data(SHA256.hash(data: state.stateHash + hash))

        state.entityCount = 1
        state.tick = 0
    }
}

// =====================================================
// MARK: - GENESIS HASH (H₀ IMMUTABILITY SEAL)
// =====================================================

public enum DVSMGenesisHash {

    public static func seal(
        state: DVSMState
    ) -> Data {

        let final =
            state.stateHash +
            withUnsafeBytes(of: state.tick.bigEndian, Array.init)

        return Data(SHA256.hash(data: final))
    }
}

