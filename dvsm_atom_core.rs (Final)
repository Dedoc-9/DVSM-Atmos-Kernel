#[repr(u8)]
pub enum DVSMRealityLayer {

    /// Reference semantic model (Rust-like execution truth)
    Reference = 0,

    /// Portable execution mirror (WASM semantic projection)
    WasmMirror = 1,

    /// Physical execution witness (TEE / SGX / hardware attest)
    HardwareWitness = 2,

    /// Network causality projection (distributed ordering view)
    NetworkCausal = 3,
}

