            s.reject = true
            s.divergenceIndex += 0.2
        }

        // ---------------------------------------------
        // GATE 3: VELOCITY CLAMP (stabilization layer)
        // ---------------------------------------------
        s.velocityX = min(max(s.velocityX, -1000), 1000)
        s.velocityY = min(max(s.velocityY, -1000), 1000)

        // ---------------------------------------------
        // GATE 4: DIVERGENCE FILTER
        // ---------------------------------------------
        if s.divergenceIndex > 0.75 {
            s.reject = true
