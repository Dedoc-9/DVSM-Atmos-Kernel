// =====================================================

public enum DVSMInputIntegrityEngine {

    // ENTRY POINT
    public static func evaluate(
        packet: DVSMInputPacket
    ) -> DVSMInputIntegrityState {

        let nodes = decompose(packet.rawBytes, depth: 0)

        let score = evaluateNodes(nodes)

        if score < 0.3 {
            return .adversarialRejected
        }

        if score < 0.6 {
            return .corrupted
        }

        if score < 0.85 {
            return .suspicious
        }

        return .valid
    }

    // =================================================
    // RECURSIVE DECOMPOSITION
    // =================================================

    private static func decompose(
        _ data: Data,
        depth: UInt8
    ) -> [DVSMInputNode] {

        // Stop recursion at max depth
        guard depth < 8 else {
            return [DVSMInputNode(fragment: data, depth: depth)]
        }

        // Split data deterministically
        let mid = data.count / 2

        guard mid > 0 else {
            return [DVSMInputNode(fragment: data, depth: depth)]
        }

        let left = data.prefix(mid)
        let right = data.suffix(from: mid)

        return decompose(Data(left), depth: depth + 1)
            + decompose(Data(right), depth: depth + 1)
    }

    // =================================================
    // INTEGRITY SCORING FUNCTION
    // =================================================

    private static func evaluateNodes(
        _ nodes: [DVSMInputNode]
    ) -> Double {

        var score: Double = 1.0

        for node in nodes {

            // Rule 1: entropy spikes indicate adversarial structure
            let entropy = pseudoEntropy(node.fragment)

            if entropy > 0.92 {
                score -= 0.2
            }

            // Rule 2: repeated structure = compression attack risk
            if isHighlyRepetitive(node.fragment) {
                score -= 0.15
            }

            // Rule 3: depth anomalies indicate crafted payloads
            if node.depth > 6 {
                score -= 0.1
            }
        }

        return max(0.0, score)
    }

    // =================================================
    // HEURISTICS
    // =================================================

    private static func pseudoEntropy(_ data: Data) -> Double {
        guard !data.isEmpty else { return 0.0 }

        let freq = Dictionary(grouping: data, by: { $0 })
        let total = Double(data.count)

        var entropy: Double = 0

        for (_, values) in freq {
            let p = Double(values.count) / total
            entropy -= p * log2(p)
        }

        return entropy / 8.0
    }

    private static func isHighlyRepetitive(_ data: Data) -> Bool {
        guard data.count > 4 else { return false }

        return Set(data).count < data.count / 4
    }
