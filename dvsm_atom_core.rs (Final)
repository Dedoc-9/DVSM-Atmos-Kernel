        for k in 1..<trajectory.count / 2 {

            let pattern = trajectory.prefix(k)

            let repeated = stride(
                from: 0,
                to: trajectory.count,
                by: k
            ).map { offset in
                trajectory[Swift.min(offset, trajectory.count - 1)]
            }

            if repeated.starts(with: pattern) {
                return .periodic(cycleLength: k)
            }
        }

        // -------------------------------------------------
        // ERGODICITY HEURISTIC
        // -------------------------------------------------

        let uniqueStates = Set(trajectory)

        if uniqueStates.count > trajectory.count / 2 {
            return .ergodic
        }

        // -------------------------------------------------
        // STRATIFICATION DETECTION
        // -------------------------------------------------

        let entropyBuckets = Dictionary(grouping: trajectory) {
            $0.prefix(2)
        }

        if entropyBuckets.count > 3 {
            return .stratified(classes: entropyBuckets.count)
        }

        // -------------------------------------------------
        // CHAOS DETECTION (SENSITIVITY TEST)
        // -------------------------------------------------

        if omegaDeterminismCheck {
            let divergence = zip(trajectory, trajectory.dropFirst()).filter { $0 != $1 }.count

            if divergence > trajectory.count / 2 {
                return .chaotic
            }
        }

        // -------------------------------------------------
        // FALLBACK: SINGULARITY COLLAPSE
        // -------------------------------------------------

        return .singularCollapse
    }
}

