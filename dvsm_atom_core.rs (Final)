pub enum DVSMReconciliationDecision {

    /// All layers agree
    Converged,

    /// Partial agreement, acceptable drift
    SoftDivergence,

    /// Structural conflict detected
    HardConflict,

    /// Invalid attestation chain
    InvalidWitness,
}

pub struct DVSMReconciliationEngine;

impl DVSMReconciliationEngine {

    pub fn settle(state: DVSMLatticeState) -> DVSMReconciliationDecision {

        let ref_h = state.reference_trace.state_hash;
        let wasm_h = state.wasm_trace.state_hash;
        let hw_h = state.hardware_trace.state_hash;
        let net_h = state.network_trace.state_hash;

        // -------------------------------------------------
        // FULL CONSENSUS
        // -------------------------------------------------

        if ref_h == wasm_h && wasm_h == hw_h && hw_h == net_h {
            return DVSMReconciliationDecision::Converged;
        }

        // -------------------------------------------------
        // HARD CONFLICT (hardware disagrees fundamentally)
        // -------------------------------------------------

        if hw_h != ref_h && hw_h != wasm_h {
            return DVSMReconciliationDecision::InvalidWitness;
        }

        // -------------------------------------------------
        // SOFT DIVERGENCE (expected multi-execution drift)
        // -------------------------------------------------

        if ref_h == wasm_h || ref_h == net_h {
            return DVSMReconciliationDecision::SoftDivergence;
        }

        // -------------------------------------------------
        // DEFAULT FAILURE MODE
        // -------------------------------------------------

        DVSMReconciliationDecision::HardConflict
    }
}

