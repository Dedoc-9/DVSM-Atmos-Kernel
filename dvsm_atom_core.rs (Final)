public enum DVSMEvolutionEngine {

    // ---------------------------------------------
    // PROPOSE RULE CHANGE
    // ---------------------------------------------

    public static func propose(
        current: DVSMRuleSetVersion,
        patch: DVSMRuleProposal
    ) -> DVSMEvolutionResult {

        guard patch.baseVersion == current.version else {
            return DVSMEvolutionResult(
                valid: false,
                projectedDivergence: 1.0,
                projectedSlashingLoad: 1.0
            )
        }

        // simulate deterministic impact
        let divergence =
            simulateDivergence(patch.diffPayload)

        let slashing =
            simulateEconomicLoad(patch.diffPayload)

        let valid =
            divergence < 0.2 && slashing < 0.3

        return DVSMEvolutionResult(
            valid: valid,
            projectedDivergence: divergence,
            projectedSlashingLoad: slashing
        )
    }

    // ---------------------------------------------
    // COMMIT EVOLUTION
    // ---------------------------------------------

    public static func commit(
        current: DVSMRuleSetVersion,
        proposal: DVSMRuleProposal,
        result: DVSMEvolutionResult
    ) -> DVSMRuleSetVersion? {

        guard result.valid else {
            return nil
        }

        let newHash = SHA256.hash(data: proposal.diffPayload)

        return DVSMRuleSetVersion(
            version: current.version + 1,
            configHash: Data(newHash)
        )
    }
}
