    public let entropy: Data
}

// =====================================================
// MARK: - GENESIS STATE (S₀)
// =====================================================

public enum DVSMGenesisState {

    public static func construct(
        _ context: DVSMGenesisContext
    ) -> DVSMState {

        let seedHash =
            Data(SHA256.hash(data: withUnsafeBytes(of: context.seed.bigEndian, Array.init)))

        let entropyHash =
            Data(SHA256.hash(data: context.entropy))

        let combined =
            seedHash + entropyHash

        let stateHash =
            Data(SHA256.hash(data: combined))

        return DVSMState(
            entityCount: 0,
            tick: 0,
            entropySeed: combined,
            stateHash: stateHash
        )
    }
}

// =====================================================
// MARK: - OMEGA (Ω) TICK AUTHORITY BOOTSTRAP
// =====================================================

public enum DVSMOmega {

    // =================================================
    // INITIALIZATION OF CAUSAL TIME ENGINE
    // =================================================

    public static func initialize(
        genesis: DVSMState
    ) -> DVSMOmegaHandle {

        return DVSMOmegaHandle(
            lastStateHash: genesis.stateHash,
            lastTick: genesis.tick
        )
    }

    // =================================================
    // NEXT TICK DERIVATION (CAUSAL TIME)
    // =================================================

    public static func nextTick(
        handle: DVSMOmegaHandle,
        newState: DVSMState
    ) -> UInt64 {

        let combined =
            handle.lastStateHash + newState.stateHash

        let derived =
            Data(SHA256.hash(data: combined))

        let value =
            derived.prefix(8).withUnsafeBytes {
                $0.load(as: UInt64.self)
            }

        return value
    }
}

// =====================================================
// MARK: - OMEGA HANDLE (CAUSAL MEMORY)
// =====================================================

public struct DVSMOmegaHandle {

    public var lastStateHash: Data

    public var lastTick: UInt64
}

// =====================================================
// MARK: - FIRST EVENT INJECTION (GENESIS PULSE)
