public struct DVSMEvent {

    public let type: DVSMEventType

    public let entityID: UInt64

    public let payloadHash: Data

    public let rejectionReasonHash: Data?

    public let timestampCanonical: UInt64
}

// =====================================================
// MARK: - ΣI (INPUT CLOSURE LAYER)
// =====================================================

public enum DVSMSigmaInputClosure {

    // =================================================
    // TOTAL INPUT MAP
    // =================================================

    /// Converts ANY byte sequence into a total event.
    /// No undefined states exist after this function.
    public static func map(
        _ input: DVSMRawBytes
    ) -> DVSMEvent {

        // ---------------------------------------------
        // STEP 1: EMPTY INPUT HANDLING
        // ---------------------------------------------

        guard !input.buffer.isEmpty else {
            return makeRejection(
                reason: "EMPTY_INPUT"
            )
        }

        // ---------------------------------------------
        // STEP 2: STRUCTURAL VALIDATION
        // ---------------------------------------------

        if input.buffer.count < 8 {
            return makeRejection(
                reason: "TRUNCATED_INPUT"
            )
        }

        // ---------------------------------------------
        // STEP 3: ENTITY EXTRACTION (DETERMINISTIC)
        // ---------------------------------------------

        let entityID = extractUInt64(input.buffer)

        // ---------------------------------------------
        // STEP 4: PAYLOAD HASH (CANONICAL)
        // ---------------------------------------------

        let payloadHash =
            Data(SHA256.hash(data: Data(input.buffer)))

        // ---------------------------------------------
        // STEP 5: OVERFLOW / CORRUPTION CHECK
        // ---------------------------------------------

        let entropy =
            input.buffer.reduce(0) { $0 &+ UInt64($1) }

        if entropy == 0 {
            return makeRejection(reason: "ZERO_ENTROPY")
        }

        // ---------------------------------------------
        // STEP 6: VALID EVENT CONSTRUCTION
        // ---------------------------------------------

        return DVSMEvent(
            type: .valid,
            entityID: entityID,
            payloadHash: payloadHash,
            rejectionReasonHash: nil,
            timestampCanonical: canonicalTime()
        )
    }

    // =================================================
    // REJECTION EVENT CONSTRUCTOR
    // =================================================

    private static func makeRejection(reason: String) -> DVSMEvent {

        let reasonHash =
            Data(SHA256.hash(data: Data(reason.utf8)))

        return DVSMEvent(
            type: .rejection,
            entityID: 0,
            payloadHash: reasonHash,
            rejectionReasonHash: reasonHash,
            timestampCanonical: canonicalTime()
        )
    }

    // =================================================
    // CANONICAL UINT64 EXTRACTION
    // =================================================

    private static func extractUInt64(
        _ buffer: [UInt8]
    ) -> UInt64 {

        var value: UInt64 = 0

        for i in 0..<8 {
            value |= UInt64(buffer[i]) << (8 * i)
        }

        return value
    }

    // =================================================
    // CANONICAL TIME (DETERMINISTIC PLACEHOLDER)
    // =================================================

    private static func canonicalTime() -> UInt64 {

        // NOTE:
        // In full DVSM deployment this is NOT system time.
        // It is tick-derived logical time from F.

        return 0
    }
}

