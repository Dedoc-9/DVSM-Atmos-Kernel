            NoiseDecision::Pass => true,
            _ => false,
        };

        if !noise_ok {
            return TickResult {
                echo: 0,
                zk: None,
                shard_score: 0,
                rejected: true,
            };
        }

        // ------------------------------------------------------------
        // LAYER 3: Ξ_COLLAPSE (STATE MUTATION)
        // ------------------------------------------------------------
        self.cdi.advance();

        self.apply_physics(); // deterministic integration step

        // ------------------------------------------------------------
        // LAYER 3.5: SHARD THERMODYNAMIC SCORING
        // ------------------------------------------------------------
