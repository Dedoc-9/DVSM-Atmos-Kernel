pub type Fx = i64; // Q32.32 fixed-point (no floats allowed)

const TICK_HZ: u32 = 60;

// ----------------------------------------------------------------------------
// ENTITY STORAGE (STRUCT OF ARRAYS ECS)
// ----------------------------------------------------------------------------

pub struct World {
    pub entities: Vec<u32>,
    pub pos: Vec<[Fx; 3]>,
    pub vel: Vec<[Fx; 3]>,
    pub grid: SpatialGrid,
    pub command_buffer: CommandBuffer,
}

// ----------------------------------------------------------------------------
// COMMAND SYSTEM (ENTROPY LAYER)
// ----------------------------------------------------------------------------

pub enum CommandType {
    Create(u32),
    Destroy(u32),
    SetPos(u32, [Fx; 3]),
    SetVel(u32, [Fx; 3]),
}

pub struct Command {
    pub cmd: CommandType,
}

pub struct CommandBuffer {
    pub buffer: Vec<Command>,
}

impl CommandBuffer {
    pub fn new() -> Self {
        Self { buffer: Vec::new() }
    }

    pub fn push(&mut self, cmd: Command) {
        self.buffer.push(cmd);
    }

    pub fn clear(&mut self) {
        self.buffer.clear();
    }
}

