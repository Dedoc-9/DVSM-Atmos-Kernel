            entity_density: self.world.entities.len() as u32,
            movement_entropy: commands_entropy,
            interaction_pressure: commands_entropy / 2,
        };

        let shard_score = self.shard.score(shard_metrics);

        // ------------------------------------------------------------
        // LAYER 4: S_ECHO (STATE FOLD HASH)
        // ------------------------------------------------------------
        let echo = self.s_echo();

        // ------------------------------------------------------------
        // LAYER 6: CONSENSUS VALIDATION
        // ------------------------------------------------------------
        let consensus_ok =
            self.consensus.validate(shard_votes, echo);

        if !consensus_ok {
            return TickResult {
                echo,
                zk: None,
                shard_score,
                rejected: true,
            };
        }

        // ------------------------------------------------------------
        // LAYER 5: ZK-SYNC PROOF GENERATION
        // ------------------------------------------------------------
        let zk = Some(ZkProof {
            echo,
            cdi: self.cdi.depth,
            shard_root: shard_score as u64,
        });

        // ------------------------------------------------------------
        // FINAL OUTPUT (S_ECHO COMMIT)
        // ------------------------------------------------------------
        TickResult {
            echo,
            zk,
            shard_score,
            rejected: false,
        }
    }

    // ========================================================================
    // PHYSICS STEP (DETERMINISTIC INTEGRATION)
    // ========================================================================

    #[inline(always)]
    fn apply_physics(&mut self) {
        for i in 0..self.world.pos.len() {
            self.world.pos[i][0] += self.world.vel[i][0] / 60;
            self.world.pos[i][1] += self.world.vel[i][1] / 60;
            self.world.pos[i][2] += self.world.vel[i][2] / 60;
        }
    }

    // ========================================================================
    // S_ECHO (GLOBAL STATE HASH)
    // ========================================================================

    #[inline(always)]
    fn s_echo(&self) -> u64 {
        let mut h: u64 = 0xcbf29ce484222325;

        for p in &self.world.pos {
            h ^= p[0] as u64;
            h = h.wrapping_mul(1099511628211);
            h ^= p[1] as u64;
            h = h.wrapping_mul(1099511628211);
            h ^= p[2] as u64;
            h = h.wrapping_mul(1099511628211);
        }

        h
    }
