    pub cells: [[Vec<u32>; 32]; 32],
    pub cell_size: Fx,
}

impl SpatialGrid {
    pub fn update(&mut self, _pos: &[[Fx; 3]]) {
        // rebuild spatial partition (deterministic)
    }
}

// ----------------------------------------------------------------------------
// COLLAPSE ENGINE (Ξ OPERATOR)
// ----------------------------------------------------------------------------

impl World {

    pub fn tick(&mut self) {

        // ============================================================
        // STEP 1: FREEZE ENTROPY
        // ============================================================
        let commands = std::mem::take(&mut self.command_buffer.buffer);

        // ============================================================
        // STEP 2: APPLY COLLAPSE (Ξ_COLLAPSE_COMMIT)
        // ============================================================
        for cmd in commands {

            match cmd.cmd {

                CommandType::Create(id) => {
                    self.entities.push(id);
                    self.pos.push([0,0,0]);
                    self.vel.push([0,0,0]);
                }

                CommandType::Destroy(id) => {
                    self.remove_entity(id);
                }

                CommandType::SetPos(id, p) => {
                    if let Some(i) = self.index_of(id) {
                        self.pos[i] = p;
                    }
                }

                CommandType::SetVel(id, v) => {
                    if let Some(i) = self.index_of(id) {
                        self.vel[i] = v;
                    }
                }
            }
        }

        // ============================================================
        // STEP 3: PHYSICS INTEGRATION (DETERMINISTIC)
        // ============================================================
        for i in 0..self.entities.len() {
            self.pos[i][0] += self.vel[i][0] / TICK_HZ as Fx;
            self.pos[i][1] += self.vel[i][1] / TICK_HZ as Fx;
            self.pos[i][2] += self.vel[i][2] / TICK_HZ as Fx;
        }

        // ============================================================
        // STEP 4: SPATIAL GRID UPDATE
        // ============================================================
        self.grid.update(&self.pos);

        // ============================================================
        // STEP 5: EMIT S_ECHO (STATE HASH)
        // ============================================================
        let hash = self.s_echo();
        self.emit(hash);
    }

    // ----------------------------------------------------------------------------
    // STATE HASH (S_ECHO)
    // ----------------------------------------------------------------------------

    pub fn s_echo(&self) -> u64 {
        let mut h: u64 = 0xcbf29ce484222325;

        for p in &self.pos {
            h ^= p[0] as u64;
            h = h.wrapping_mul(1099511628211);
            h ^= p[1] as u64;
            h = h.wrapping_mul(1099511628211);
            h ^= p[2] as u64;
            h = h.wrapping_mul(1099511628211);
        }

        h
    }

    pub fn emit(&self, hash: u64) {
        // network broadcast (authoritative truth)
        // ONLY this defines reality per tick
        println!("S_ECHO::{}", hash);
    }

    // ----------------------------------------------------------------------------
    // ENTITY HELPERS
    // ----------------------------------------------------------------------------

    fn index_of(&self, id: u32) -> Option<usize> {
        self.entities.iter().position(|x| *x == id)
    }

    fn remove_entity(&mut self, id: u32) {
        if let Some(i) = self.index_of(id) {
            self.entities.remove(i);
            self.pos.remove(i);
            self.vel.remove(i);
        }
    }
}

