    #[inline(always)]
    pub fn tick(
        &mut self,
        commands_entropy: u64,
        shard_votes: &[u64],
    ) -> TickResult {

        // ------------------------------------------------------------
        // LAYER 1: CDI (CAUSAL VALIDATION GATE)
        // ------------------------------------------------------------
        let cdi_ok = self.cdi.validate(self.cdi.depth + 1);

        // ------------------------------------------------------------
        // LAYER 2: NOISE / GHOST FILTER
        // ------------------------------------------------------------
