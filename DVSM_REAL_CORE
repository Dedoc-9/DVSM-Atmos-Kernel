// ============================================================================
// 7. WORLD CORE (Ξ_COLLAPSE ENGINE)
// ============================================================================

pub struct World {
    pub ecs: DenseWorld,
    pub commands: CommandBuffer,
    pub cdi: CDI,
    pub noise: NoiseGovernor,
    pub shard: ShardEvaluator,
    pub tick: u64,
}

impl World {

    // ============================================================
    // MAIN TICK (Ξ_COLLAPSE)
    // ============================================================

    pub fn tick(&mut self) -> Option<u64> {

        self.tick += 1;
        self.cdi.tick = self.tick;

        // --------------------------------------------------------
        // 1. NOISE FILTER (ANTI-CHEAT LAYER)
        // --------------------------------------------------------
        if !self.noise.filter(self.commands.buffer.len()) {
            self.commands.clear();
            return None; // VOID STATE (not repaired, rejected)
        }

        // --------------------------------------------------------
        // 2. APPLY COMMANDS (DETERMINISTIC ORDER ONLY)
        // --------------------------------------------------------
        let cmds = std::mem::take(&mut self.commands.buffer);

        for c in cmds {
            match c {
                Command::Create(id) => {
                    self.ecs.entities.push(id);
                    self.ecs.pos.push([0; 3]);
                    self.ecs.vel.push([0; 3]);
                }

                Command::Destroy(id) => {
                    if let Some(i) = self.index(id) {
                        self.remove(i);
                    }
                }

                Command::SetPos(id, p) => {
                    if let Some(i) = self.index(id) {
                        self.ecs.pos[i] = p;
                    }
                }

                Command::SetVel(id, v) => {
                    if let Some(i) = self.index(id) {
                        self.ecs.vel[i] = v;
                    }
                }
            }
        }

        // --------------------------------------------------------
        // 3. DETERMINISTIC PHYSICS (FIXED POINT ONLY)
        // --------------------------------------------------------
        for i in 0..self.ecs.entities.len() {
            self.ecs.pos[i][0] = fx_mul(self.ecs.vel[i][0], 1);
            self.ecs.pos[i][1] = fx_mul(self.ecs.vel[i][1], 1);
            self.ecs.pos[i][2] = fx_mul(self.ecs.vel[i][2], 1);
        }

        // --------------------------------------------------------
        // 4. SHARD EVALUATION (LOAD BALANCE SIGNAL ONLY)
        // --------------------------------------------------------
        let shard_score = self.shard.score();

        // --------------------------------------------------------
        // 5. S_ECHO (FINAL STATE HASH)
        // --------------------------------------------------------
        Some(self.s_echo(shard_score))
    }

    // ========================================================================
    // S_ECHO (DETERMINISTIC FINALITY HASH)
    // ========================================================================

    pub fn s_echo(&self, shard: u64) -> u64 {

        let mut h: u64 = 0xcbf29ce484222325;
        h = mix_hash(h, shard);
        h = mix_hash(h, self.ecs.entities.len() as u64);

        for p in &self.ecs.pos {
            h = mix_hash(h, p[0] as u64);
            h = mix_hash(h, p[1] as u64);
            h = mix_hash(h, p[2] as u64);
        }

        h
    }

    // ========================================================================
    // HELPERS (DETERMINISTIC INDEXING)
    // ========================================================================

    fn index(&self, id: EntityId) -> Option<usize> {
        self.ecs.entities.iter().position(|x| *x == id)
    }

    fn remove(&mut self, i: usize) {
        self.ecs.entities.swap_remove(i);
        self.ecs.pos.swap_remove(i);
        self.ecs.vel.swap_remove(i);
    }
}

