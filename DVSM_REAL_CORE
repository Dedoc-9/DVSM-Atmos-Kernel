#![allow(non_camel_case_types)]

// ----------------------------------------------------------------------------
// FIXED-POINT CORE
// ----------------------------------------------------------------------------

pub type Fx = i64; // Q32.32 deterministic fixed-point

const TICK_HZ: u32 = 60;

// ----------------------------------------------------------------------------
// COMMAND SYSTEM (ENTROPY BUFFER)
// ----------------------------------------------------------------------------

pub enum CommandType {
    Create(u32),
    Destroy(u32),
    SetPos(u32, [Fx; 3]),
    SetVel(u32, [Fx; 3]),
}

pub struct Command {
    pub cmd: CommandType,
}

pub struct CommandBuffer {
    pub buffer: Vec<Command>,
}

impl CommandBuffer {
    pub fn new() -> Self {
        Self { buffer: Vec::new() }
    }

    pub fn push(&mut self, cmd: Command) {
        self.buffer.push(cmd);
    }

    pub fn clear(&mut self) {
        self.buffer.clear();
    }
}

// ----------------------------------------------------------------------------
// SPATIAL GRID (INTEREST MANAGEMENT)
// ----------------------------------------------------------------------------

pub struct SpatialGrid {
    pub cells: [[Vec<u32>; 32]; 32],
    pub cell_size: Fx,
}

impl SpatialGrid {
    pub fn update(&mut self, _pos: &[[Fx; 3]]) {
        // deterministic spatial rebuild (no side effects)
    }
}

// ----------------------------------------------------------------------------
// WORLD STATE (POST-COLLAPSE ECS)
// ----------------------------------------------------------------------------

pub struct World {
    pub entities: Vec<u32>,
    pub pos: Vec<[Fx; 3]>,
    pub vel: Vec<[Fx; 3]>,
    pub grid: SpatialGrid,
    pub command_buffer: CommandBuffer,
}

// ----------------------------------------------------------------------------
// COLLAPSE ENGINE (Ξ OPERATOR)
// ----------------------------------------------------------------------------

impl World {

    pub fn tick(&mut self) {

        // ============================================================
        // STEP 1 — FREEZE ENTROPY
        // ============================================================
        let commands = std::mem::take(&mut self.command_buffer.buffer);

        // ============================================================
        // STEP 2 — Ξ_COLLAPSE (DETERMINISTIC COMMIT)
        // ============================================================
        for cmd in commands {
            match cmd.cmd {

                CommandType::Create(id) => {
                    self.entities.push(id);
                    self.pos.push([0, 0, 0]);
                    self.vel.push([0, 0, 0]);
                }

                CommandType::Destroy(id) => {
                    self.remove_entity(id);
                }

                CommandType::SetPos(id, p) => {
                    if let Some(i) = self.index_of(id) {
                        self.pos[i] = p;
                    }
                }

                CommandType::SetVel(id, v) => {
                    if let Some(i) = self.index_of(id) {
                        self.vel[i] = v;
                    }
                }
            }
        }

        // ============================================================
        // STEP 3 — DETERMINISTIC PHYSICS INTEGRATION
        // ============================================================
        for i in 0..self.entities.len() {
            self.pos[i][0] += self.vel[i][0] / TICK_HZ as Fx;
            self.pos[i][1] += self.vel[i][1] / TICK_HZ as Fx;
            self.pos[i][2] += self.vel[i][2] / TICK_HZ as Fx;
        }

        // ============================================================
        // STEP 4 — SPATIAL GRID UPDATE
        // ============================================================
        self.grid.update(&self.pos);

        // ============================================================
        // STEP 5 — S_ECHO EMISSION (STATE IDENTITY)
        // ============================================================
        let echo = self.s_echo();
        self.emit(echo);
    }

    // ----------------------------------------------------------------------------
    // S_ECHO — STATE HASH (ONLY PERSISTENT IDENTITY)
    // ----------------------------------------------------------------------------

    pub fn s_echo(&self) -> u64 {
        let mut h: u64 = 0xcbf29ce484222325;

        for p in &self.pos {
            h ^= p[0] as u64;
            h = h.wrapping_mul(1099511628211);

            h ^= p[1] as u64;
            h = h.wrapping_mul(1099511628211);

            h ^= p[2] as u64;
            h = h.wrapping_mul(1099511628211);
        }

        h
    }

    pub fn emit(&self, hash: u64) {
        // authoritative broadcast of collapsed state identity
        println!("S_ECHO::{}", hash);
    }

    // ----------------------------------------------------------------------------
    // ENTITY HELPERS
    // ----------------------------------------------------------------------------

    fn index_of(&self, id: u32) -> Option<usize> {
        self.entities.iter().position(|x| *x == id)
    }

    fn remove_entity(&mut self, id: u32) {
        if let Some(i) = self.index_of(id) {
            self.entities.remove(i);
            self.pos.remove(i);
            self.vel.remove(i);
        }
    }
}

