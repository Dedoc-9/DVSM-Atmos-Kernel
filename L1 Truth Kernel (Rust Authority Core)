// MARK: - L3 & L5: EXECUTION & REPLAY SYMMETRY

public final class DVSMCompetitiveArena {
    private var currentState: DVSMStateHeader
    private let manifold = DVSMIntegrityManifold()

    /**
     PIPELINE: DETERMINISTIC STATE EVOLUTION
     1. L1 global state -> L2 PSM projection.
     2. PSM -> Reachable Set via stateless solver (C, L, E).
     3. T validated via strict set-membership predicate.
     4. COMMIT: If T ∈ Reach(PSM), evolve L1 state normally.
     5. ENCODE: If T ∉ Reach(PSM), evolve L1 to deterministic fault state (L6).
     */
    public func pulse(input: DVSMTransition, agentID: Int) {
        
        // Step 1 & 2: Manifold Generation
        let psm = manifold.projectPSM(globalState: currentState, agentID: agentID)
        let reachableSet = manifold.computeReachableSet(psm: psm)
        
        // Step 3: POCR RULE (Geometric Constraint Evaluation)
        if reachableSet.contains(input) {
            // VALID PATH
            self.commit(input)
        } else {
            // Step 5: L6 DETERMINISTIC ENCODING
            // Failure is a first-class event in the state transition graph.
            // All nodes converge to identical state traces including fault events.
            self.fault(reason: .causalOrphan)
        }
    }

    private func commit(_ t: DVSMTransition) {
        // Standard deterministic state evolution
        self.currentState = DVSMKernel.evolve(currentState, with: t)
    }

    private func fault(reason: DVSMIntegritySignal) {
        // L6: Deterministic evolution of the hash chain under fault conditions.
        // Preserves L5 distributed consistency by removing divergence risk.
        self.currentState = DVSMKernel.injectFault(currentState, reason: reason)
    }
}

