// MARK: - SEED EVOLUTION ENGINE (PURE)

public enum DVSMSeedEngine {
    /// Seed(n+1) = Truncate64(HMAC-SHA256(Seed(n), StateHash(n)))
    public static func next(seed: UInt64, stateHash: Data) -> UInt64 {
        let seedBytes = withUnsafeBytes(of: seed.bigEndian) { Data($0) }
        let hmacResult = HMAC_SHA256(key: seedBytes + stateHash, data: stateHash)
        return hmacResult.prefix(8).withUnsafeBytes { $0.load(as: UInt64.self).bigEndian }
    }
}

