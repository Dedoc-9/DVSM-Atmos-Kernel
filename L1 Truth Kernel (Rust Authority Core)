        // 2. RESOLVE (Pure entropy projection; no mutable state)
        let resolved = pulse.map { intent in
            self.solveInjectiveMorphism(
                intent, 
                in: psm, 
                seed: pulseSeed
            ) ?? DVSMCanonicalFault.image(of: intent, reason: .causalOrphan)
        }
        
        // 3. REDUCE (Canonical injective resolution)
        let uniquePulse = DVSMInjectiveResolver.reduce(resolved)
        
        // 4. SERIALIZE (L4 Physical Substrate Normalization)
        let canonicalBytes = DVSML4Substrate.encodeState(
            sequence: self.currentState.sequence + 1,
            entityVectors: uniquePulse.vectors,
            faultStatus: uniquePulse.faultFlag
        )
        
        // 5. EVOLVE (Update Truth Kernel & Evolve Seed)
        let nextSeed = DVSMSeedEngine.next(seed: pulseSeed, stateHash: self.currentState.stateHash)
        return self.evolve(from: canonicalBytes, nextSeed: nextSeed)
    }
