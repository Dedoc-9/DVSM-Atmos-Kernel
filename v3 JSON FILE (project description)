import Foundation

// =====================================================
// MARK: - STATE OBJECT (CANONICAL SYSTEM STATE)
// =====================================================

public struct DVSMState {

    public let stateHash: Data
    public let replayHash: Data
    public let executionHash: Data

    public let lamportClock: UInt64
    public let shardID: String

    public let attractorMetric: Double

    public init(
        stateHash: Data,
        replayHash: Data,
        executionHash: Data,
        lamportClock: UInt64,
        shardID: String,
        attractorMetric: Double
    ) {
        self.stateHash = stateHash
        self.replayHash = replayHash
        self.executionHash = executionHash
        self.lamportClock = lamportClock
        self.shardID = shardID
        self.attractorMetric = attractorMetric
    }
}

// =====================================================
// MARK: - STATE TRANSITION FUNCTION (F)
// =====================================================

public struct DVSMStateTransitionFunction {

    /// F(state, event) → next state
    public static func apply(
        _ state: DVSMState,
        event: Data,
        clock: UInt64,
        shard: String
    ) -> DVSMState {

        let replayHash = SHA256.hash(data: state.replayHash + event)
        let executionHash = SHA256.hash(data: state.executionHash + event)

        let combined = replayHash + executionHash + event
        let newStateHash = SHA256.hash(data: combined)

        let attractor = Double(newStateHash.withUnsafeBytes {
            $0.load(as: UInt64.self)
        }) / Double(UInt64.max)

        return DVSMState(
            stateHash: Data(newStateHash),
            replayHash: Data(replayHash),
            executionHash: Data(executionHash),
            lamportClock: clock,
            shardID: shard,
            attractorMetric: attractor
        )
    }
}

// =====================================================
// MARK: - QUORUM CERTIFICATE (CONSENSUS PROOF)
// =====================================================

public struct DVSMQuorumCertificate {

    public let stateHash: Data
    public let signatures: [Data]
    public let threshold: Int

    public func isValid() -> Bool {
        return signatures.count >= threshold && !stateHash.isEmpty
    }
}

// =====================================================
// MARK: - CONSENSUS MESSAGE (NETWORK LAYER)
// =====================================================

public struct DVSMMessage {

    public let fromNode: String
    public let state: DVSMState
    public let signature: Data
    public let timestamp: UInt64
}

// =====================================================
// MARK: - FINALITY ENGINE (ACTIVE CONSENSUS PRODUCER)
// =====================================================

public final class DVSMFinalityEngine {

    private let epsilon: Double = 0.0001
    private let byzantineLimit: Double = 0.667

    private var stateBuffer: [String: DVSMState] = [:]
    private var votes: [Data: Int] = [:]

    // -------------------------------------------------
    // INGEST STATE FROM NODE
    // -------------------------------------------------

    public func ingest(_ message: DVSMMessage, nodeCount: Int) {

        let key = message.state.shardID
        stateBuffer[key] = message.state

        let hash = message.state.stateHash
        votes[hash, default: 0] += 1
    }

    // -------------------------------------------------
    // CHECK ATTRACTOR CONVERGENCE
    // -------------------------------------------------

    private func isStable(_ state: DVSMState) -> Bool {
        return state.attractorMetric <= epsilon
    }

    // -------------------------------------------------
    // CHECK BYZANTINE SAFETY
    // -------------------------------------------------

    private func isByzantineSafe(votes: Int, total: Int) -> Bool {
        return Double(votes) / Double(total) >= byzantineLimit
    }

    // -------------------------------------------------
    // FINALITY DECISION FUNCTION
    // -------------------------------------------------

    public func evaluateFinality(
        nodeCount: Int
    ) -> DVSMFinalityResult {

        guard let candidate = stateBuffer.values.first else {
            return .undecided
        }

        let voteCount = votes[candidate.stateHash] ?? 0

        let stable = isStable(candidate)
        let safe = isByzantineSafe(votes: voteCount, total: nodeCount)

        let replayEq = candidate.replayHash == candidate.executionHash

        if stable && safe && replayEq {
            return .finalized(candidate)
        }

        return .undecided
    }
}

// =====================================================
// MARK: - FINALITY RESULT SPACE
// =====================================================

public enum DVSMFinalityResult {
    case finalized(DVSMState)
    case undecided
}

// =====================================================
// MARK: - GLOBAL FINALITY KERNEL (Ω∞ ROOT COORDINATOR)
// =====================================================

public final class DVSMOmegaFinalityKernel {

    private let engine = DVSMFinalityEngine()

    public init() {}

    public func process(message: DVSMMessage, nodeCount: Int) -> DVSMFinalityResult {
        engine.ingest(message, nodeCount: nodeCount)
        return engine.evaluateFinality(nodeCount: nodeCount)
    }
}

