/// Q64.64 deterministic fixed-point representation
public struct DVSMFixedPoint: Equatable {
    public let raw: Int64
    
    public init(_ raw: Int64) {
        self.raw = raw
    }

    public static func fromDouble(_ value: Double) -> DVSMFixedPoint {
        return DVSMFixedPoint(Int64(value * Double(1 << 32)))
    }

    public func toDouble() -> Double {
        return Double(raw) / Double(1 << 32)
    }
}

