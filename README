pub fn dist_h(
    a: &StateEmbedding,
    b: &StateEmbedding,
    weights: (f64, f64, f64),
) -> f64 {
    let (alpha, beta, gamma) = weights;

    alpha * hash_distance(a.h, b.h)
    + beta * causal_distance(a.c, b.c)
    + gamma * entropy_distance(a.e, b.e)
}
