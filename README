pub struct RealityBasin {
    pub id: u64,
    pub stability: f64,
    pub rigidity: f64,
    pub chi: f64,
    pub classification: BasinClass,
}

pub enum BasinClass {
    Stable,
    Metastable,
    Bifurcation,
    Chaotic,
}

// =====================================================
// MARK: - FIXED POINT ENCODING (ABI SAFE)
// =====================================================

fn to_fixed(v: f64) -> i64 {
    // Q64.64 deterministic scaling
    (v * (1i128 << 32) as f64) as i64
}

// =====================================================
// MARK: - CONVERSION LAYER (SETTLEMENT → FFI)
// =====================================================

impl From<&RealityBasin> for FFIBasin {
    fn from(b: &RealityBasin) -> Self {
        FFIBasin {
            basin_id: b.id,

            stability: to_fixed(b.stability),
            rigidity: to_fixed(b.rigidity),
            chi: to_fixed(b.chi),

            is_stable: match b.classification {
                BasinClass::Stable => 1,
                _ => 0,
            },

            is_bifurcation: match b.classification {
                BasinClass::Bifurcation => 1,
                _ => 0,
            },
        }
    }
}

