// =====================================================
// MARK: - OMEGAFLOW ENGINE (DYNAMICS LAYER)
// =====================================================

public final class OmegaFlowEngine {

    /// Deterministic evolution step over Reality Basin manifold
    public func evolve(_ state: PsiState) -> PsiState {

        let stability = state.basin.stability
        let chi = state.basin.chi
        let force = state.externalForce

        // -------------------------------------------------
        // FLOW EQUATION (DISCRETE VECTOR FIELD)
        // -------------------------------------------------
        // Higher chi => more exploratory drift
        // Higher stability => attractor locking
        // -------------------------------------------------

        let driftComponent =
            DVSMFixedPoint.fromDouble(
                chi.toDouble() * 0.6
            )

        let attractorComponent =
            DVSMFixedPoint.fromDouble(
                stability.toDouble() * -0.8
            )

        let newGradient =
            DVSMFixedPoint(
                driftComponent.raw +
                attractorComponent.raw +
                force.raw
            )

        return PsiState(
            basin: state.basin,
            gradient: newGradient,
            externalForce: state.externalForce
        )
    }
}

