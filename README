public struct RealityBasin {
    public let members: [PsiState]
    public let stability: Double
}

// =====================================================
// MARK: - FLOW FIELD SEMANTICS
// =====================================================

/// ΩFlow does NOT simulate state.
/// It computes directional bias over RealityBasins.
public struct OmegaFlow {

    public init() {}

    // =================================================
    // MARK: Attractor Model
    // =================================================

    /// Computes the "attractor strength" of a basin.
    /// Interpretation: likelihood of persistence under perturbation.
    public func attractor(_ basin: RealityBasin) -> Double {
        let entropyPressure = basin.members
            .map { $0.chi }
            .reduce(0.0, +) / Double(max(basin.members.count, 1))

        // Stability pulls upward, entropy spreads downward
        return basin.stability - entropyPressure
    }

    // =================================================
    // MARK: Gradient Field Over Reality Space
    // =================================================

    /// Computes directional flow between two basins.
    /// This is NOT distance — it is transition pressure.
    public func flow(from: RealityBasin, to: RealityBasin) -> Double {

        let deltaStability = to.stability - from.stability

        let fromAttr = attractor(from)
        let toAttr = attractor(to)

        let attractorGradient = toAttr - fromAttr

        // ΩFlow equation:
        // motion emerges from stability + attractor differential
        return deltaStability + attractorGradient
    }

    // =================================================
    // MARK: Basin Selection Dynamics
    // =================================================

    /// Selects next-state basin under deterministic gradient rule.
    public func evolve(current: RealityBasin,
                       candidates: [RealityBasin]) -> RealityBasin? {

        guard !candidates.isEmpty else { return nil }

        return candidates.max(by: {
            flow(from: current, to: $0) < flow(from: current, to: $1)
        })
    }
}
