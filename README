import Foundation

/// Defines the high-fidelity gaming specific thresholds for 
/// the DVSM Noise Deconstructor.
public struct DVSMGameSpectraConstraints {
    
    /// The "Speed of Light" Invariant:
    /// Max fixed-point delta allowed per pulse for player movement.
    /// Prevents 'Teleportation' and 'Speed Hacks' at the Kernel level.
    public static let maxManifoldVelocity: Int64 = 1_048_576 // 1024.0 fixed
    
    /// Recoil/Script Detection Threshold:
    /// High spectral energy at specific frequencies indicates 
    /// 'Recoil Compensation Scripts' vs. Organic Human Jitter.
    public static let adversarialOscillationFloor: Double = 15.0
    
    /// Trust Persistence:
    /// Minimum EMA (Exponential Moving Average) trust required to 
    /// prevent "Lag Switching" from being used as a tactical advantage.
    public static let tacticalPersistenceFloor: Double = 0.45
}

// =====================================================
// MARK: - GAME SECURITY LOGIC EXTENSION
// =====================================================

extension DVSMSpectralObserver {
    
    /// Specialized diagnostic for FPS/Action games.
    /// Analyzes the 'Signal Conditioning' of aim and movement vectors.
    public func diagnosticGamePulse(
        flux: DVSMFixedVector, 
        persistence: Double
    ) -> DVSMCheatSignal {
        
        // 1. PHYSICAL IMPOSSIBILITY CHECK
        // If the flux values exceed the physics lattice, it is an 
        // immediate impossible transition.
        let values = flux.values
        for delta in values {
            if abs(delta) > DVSMGameSpectraConstraints.maxManifoldVelocity {
                return .impossibleTransition
            }
        }
        
        // 2. SPECTRAL SCRIPT DETECTION
        // Converts fixed-point flux to Double for FFT analysis.
        let samples = values.map { Double($0) / 1024.0 }
        let energy = self.computeSpectralEnergy(from: samples)
        
        if energy > DVSMGameSpectraConstraints.adversarialOscillationFloor {
            return .simulationDivergence // Classed as a 'Scripted' divergence
        }
        
        // 3. PERSISTENCE DAMPING
        // Low persistence over a moving window detects 'Lag Switching'.
        if persistence < DVSMGameSpectraConstraints.tacticalPersistenceFloor {
            return .causalDesync
        }
        
        return .clean
    }
}

// =====================================================
// L2.7 — DVSMSPECTRAL OBSERVER (INTEGRITY LAYER)
// Competitive Behavioral Validation Subsystem
// =====================================================
//
// PURPOSE:
// Extends L2 Observer with deterministic behavioral
// integrity constraints for competitive environments.
//
// This layer does NOT enforce state.
// It only classifies structural validity of transitions.
// =====================================================

public struct DVSMSpectralIntegrityConstraints {

    /// Kinematic Integrity Ceiling:
    /// Maximum allowed delta per pulse for state transition.
    /// Prevents physically impossible movement in state space.
    public static let maxManifoldVelocity: Int64 = 1_048_576 // 1024.0 fixed-point

    /// Spectral Noise Floor:
    /// Minimum entropy threshold expected in human input signals.
    /// Values below this indicate non-organic periodicity.
    public static let adversarialOscillationFloor: Double = 15.0

    /// Intent Persistence Floor:
    /// Measures decay of behavioral intent over time.
    /// Humans exhibit stochastic drift; perfect consistency is anomalous.
    public static let tacticalPersistenceFloor: Double = 0.45

    /// Temporal Jitter Baseline:
    /// Expected variance in reaction timing under normal conditions.
    public static let reactionVarianceFloor: Double = 0.18
}

// =====================================================
// MARK: - L2.7 SPECTRAL BEHAVIORAL OBSERVER
// =====================================================

extension DVSMSpectralObserver {

    /// L2.7 Integrity Classification Engine
    /// Evaluates whether a DVSM state transition is
    /// consistent with organic (non-automated) input behavior.
    public func validateIntegrityPulse(
        flux: DVSMFixedVector,
        persistence: Double,
        reactionVariance: Double
    ) -> DVSMIntegritySignal {

        // ---------------------------------------------
        // 1. KINEMATIC IMPOSSIBILITY CHECK
        // ---------------------------------------------
        let values = flux.values

        for delta in values {
            if abs(delta) > DVSMSpectralIntegrityConstraints.maxManifoldVelocity {
                return .manifoldViolation
            }
        }

        // ---------------------------------------------
        // 2. SPECTRAL ANALYSIS (HUMAN NOISE MODEL)
        // ---------------------------------------------
        let samples = values.map { Double($0) / 1024.0 }
        let spectralEnergy = self.computeSpectralEnergy(from: samples)

        if spectralEnergy < DVSMSpectralIntegrityConstraints.adversarialOscillationFloor {
            return .deterministicScriptPattern
        }

        // ---------------------------------------------
        // 3. INTENT CONSISTENCY CHECK
        // ---------------------------------------------
        if persistence < DVSMSpectralIntegrityConstraints.tacticalPersistenceFloor {
            return .intentDesync
        }

        // ---------------------------------------------
        // 4. REACTION VARIANCE CHECK
        // ---------------------------------------------
        if reactionVariance < DVSMSpectralIntegrityConstraints.reactionVarianceFloor {
            return .nonHumanTimingSignature
        }

        return .clean
    }
}

