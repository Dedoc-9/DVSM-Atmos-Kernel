// dvsm-dist-h/src/lib.rs

pub mod state;
pub mod metric;
pub mod axioms;

/// The core Result of a DVSM metric evaluation.
pub type MetricResult = f64;

/// Threshold for epsilon-reachability (ε_H).
pub const EPSILON_H: MetricResult = 0.00001; 

/// The Primary Trait for History-Sealed States.
pub trait SealedState {
    fn hash_divergence(&self, other: &Self) -> MetricResult;
    fn causal_divergence(&self, other: &Self) -> MetricResult;
    fn entropy_divergence(&self, other: &Self) -> MetricResult;
    
    /// The Composite Metric (dist_H)
    /// dist_H = α·d_hash + β·d_causal + γ·d_entropy
    fn dist_h(&self, other: &Self, weights: (f64, f64, f64)) -> MetricResult {
        let (alpha, beta, gamma) = weights;
        alpha * self.hash_divergence(other) +
        beta * self.causal_divergence(other) +
        gamma * self.entropy_divergence(other)
    }
}
