// dvsm-dist-h/src/state.rs

use sha2::{Sha256, Digest};

/// Canonical DVSM state representation
/// NOT a snapshot — a history-sealed causal fingerprint.
pub trait DVSMState {
    /// Cryptographic identity of this state node
    fn state_hash(&self) -> [u8; 32];

    /// Structural causal footprint (not time-based)
    fn causal_fingerprint(&self) -> [u8; 32];

    /// Entropic encoding of internal variability
    fn entropy_signature(&self) -> f64;

    /// Canonical embedding into metric space
    fn embed(&self) -> StateEmbedding {
        StateEmbedding {
            h: self.state_hash(),
            c: self.causal_fingerprint(),
            e: self.entropy_signature(),
        }
    }
}

