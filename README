public struct BasinDivergenceReport {

    /// Unique identifier of the Reality Basin
    public let basinID: UInt64

    /// Stability score (0.0 = chaotic, 1.0 = rigid attractor)
    public let stability: Double

    /// Structural rigidity of causal constraints
    public let rigidity: Double

    /// Residual entropy (χ) — measure of concurrency fluidity
    public let chi: Double

    /// Whether OmegaFlow converged to a stable attractor
    public let isStableAttractor: Bool

    /// Whether system bifurcated into multiple basins
    public let isBifurcationEvent: Bool

    /// Distance from nearest competing basin (ε-space separation)
    public let basinSeparation: Double

    /// Classification result (single deterministic label)
    public let classification: AttractorClassification
}

// =====================================================
// MARK: - ΩFLOW ATTRACTOR CLASSIFICATION RULES
// =====================================================

/*
 A "stable reality" in DVSM is NOT low entropy.

 It is:
    - convergence under perturbation
    - bounded χ (not minimal χ)
    - stable basin identity under ε-noise

 Classification is deterministic and rule-based.
*/

public enum AttractorClassification {

    /// Fully stable basin:
    /// perturbations collapse back into same Ψ-class
    case stableAttractor

    /// Minor oscillation within same basin boundary
    case metastableOrbit

    /// System is exploring multiple equivalent basins
    case bifurcationZone

    /// No convergence; causal structure is incoherent
    case chaoticDivergence
}

// =====================================================
// MARK: - CLASSIFICATION FUNCTION (1C EVALUATION RULE)
// =====================================================

/*
 1C RULE (ONE-CYCLE DECISION):

 Every basin MUST be classified in exactly ONE pass.

 No iterative re-scoring.
 No recursive stabilization.
 No second-order correction.

 This enforces L5 replay determinism.
*/

public func classifyBasin(
    stability: Double,
    rigidity: Double,
    chi: Double,
    separation: Double
) -> AttractorClassification {

    // -----------------------------------------
    // STABLE ATTRACTOR CONDITION
    // -----------------------------------------
    if stability > 0.85 && rigidity > 0.7 && separation > 0.6 {
        return .stableAttractor
    }

    // -----------------------------------------
    // METASTABLE ORBIT CONDITION
    // -----------------------------------------
    if stability > 0.6 && chi < 0.5 {
        return .metastableOrbit
    }

    // -----------------------------------------
    // BIFURCATION CONDITION
    // -----------------------------------------
    if separation < 0.3 && chi > 0.5 {
        return .bifurcationZone
    }

    // -----------------------------------------
    // DEFAULT: CHAOTIC
    // -----------------------------------------
    return .chaoticDivergence
}
