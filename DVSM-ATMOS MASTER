// =====================================================
// MARK: - HASH UTILITY
// =====================================================

fn hash(data: &[u8]) -> Hash32 {
    let mut hasher = Sha256::new();
    hasher.update(data);
    hasher.finalize().into()
}

// =====================================================
// MARK: - MANIFEST BUILDER (DETERMINISTIC)
// =====================================================

impl DVSMMasterManifest {

    pub fn build(layer_sigs: Vec<LayerSignature>) -> Self {

        // 1. Sort deterministically by discriminant ordering
        let mut ordered = layer_sigs.clone();

        ordered.sort_by_key(|l| match l.layer {
            DVSMLayer::L1_RuntimeKernel => 1,
            DVSMLayer::L2_ReachabilityManifold => 2,
            DVSMLayer::L3_TotalOrderBroadcast => 3,
            DVSMLayer::L4_ProofCarryingGate => 4,
            DVSMLayer::L5_DualAnchorTruthKernel => 5,
            DVSMLayer::L6_MetaGovernanceOmegaInfinity => 6,
            DVSMLayer::L7_HollowMerkleRedaction => 7,
        });

        // 2. Fold layer hashes into global root
        let mut accumulator: Vec<u8> = vec![];

        for sig in &ordered {
            accumulator.extend_from_slice(&sig.root_hash);
            accumulator.extend_from_slice(&sig.metadata_hash);
        }

        let global_root = hash(&accumulator);

        Self {
            layer_sigs: ordered,
            global_root,
        }
    }

    // =====================================================
    // VERIFY: BIT-STABLE CONSISTENCY CHECK
    // =====================================================

    pub fn verify(&self) -> bool {
        let recomputed = DVSMMasterManifest::build(self.layer_sigs.clone());
        recomputed.global_root == self.global_root
    }
}

