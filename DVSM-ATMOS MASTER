            nodes: HashMap::new(),
            redaction_log: vec![],
        }
    }

    // ---------------------------------------------
    // INSERT NODE (NON-REDACTED STATE ENTRY)
    // ---------------------------------------------

    pub fn insert_node(
        &mut self,
        payload: &[u8],
        parent: Option<Hash32>,
        index: u64
    ) -> Hash32 {

        let skeletal = SkeletalHash::new(payload, parent, index);

        let node = HollowMerkleNode {
            skeletal: skeletal.clone(),
            payload_hash: Some(hash(payload)),
            left: parent,
            right: None,
            redacted: false,
        };

        self.nodes.insert(skeletal.id, node);
        skeletal.id
    }

    // ---------------------------------------------
    // REDACTION OPERATION (HOLLOW TRANSFORM)
    // ---------------------------------------------

    pub fn redact(
        &mut self,
        node_id: Hash32,
        witness: RedactionWitness,
        policy: RedactionPolicy
    ) -> bool {

        let node = match self.nodes.get_mut(&node_id) {
            Some(n) => n,
            None => return false,
        };

        // Witness validation
        let policy_bytes = &policy.policy_id;
        if !witness.verify(node, policy_bytes) {
            return false;
        }

        // Quorum check placeholder (would be distributed in real system)
        if policy.quorum_threshold < 1 {
            return false;
        }

        // Perform hollowing (NOT deletion)
        node.payload_hash = None;
        node.redacted = true;

        self.redaction_log.push(node_id);

        true
    }

    // ---------------------------------------------
    // SKELETAL ROOT COMPUTATION (CAUSAL CONTINUITY)
    // ---------------------------------------------

    pub fn compute_global_root(&self) -> Hash32 {

        let mut accumulator = vec![];

        for node in self.nodes.values() {
            accumulator.extend_from_slice(&node.compute_root());
        }

        hash(&accumulator)
    }

    // ---------------------------------------------
    // SHADOW REPLAY CONSISTENCY CHECK
    // ---------------------------------------------

    pub fn verify_replay_consistency(&self) -> bool {

        let mut reconstructed = self.nodes.clone();
        let mut recomputed = vec![];

        for (_, node) in reconstructed.iter() {
            recomputed.push(node.compute_root());
        }

        let mut flat = vec![];
        for r in recomputed {
            flat.extend_from_slice(&r);
        }

        let final_hash = hash(&flat);
        final_hash == self.compute_global_root()
    }
}

