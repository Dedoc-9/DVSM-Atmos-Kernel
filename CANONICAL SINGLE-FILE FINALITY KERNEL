public final class DVSM_AMP_BlazedKernel {

    public enum State: Int {
        case void = -1
        case empty = 0
        case seeded = 1
        case frozen = 2
        case absorbing = 3
    }
    private var lattice: [[State]]
    private let size: Int

    public init(size: Int) {
        self.size = size
        self.lattice = Array(
            repeating: Array(repeating: .empty, count: size),
            count: size
        )
    }
    // ------------------------------------------------------------------------
    // S_THROW — KINETIC GATE
    // ------------------------------------------------------------------------
    public func throwSpear(r: Int, c: Int, velocity: Double) -> Bool {

        guard velocity >= 5.0 else { return false }
        guard lattice[r][c] == .empty else { return false }

        lattice[r][c] = .seeded
        return true
    }
    // ------------------------------------------------------------------------
    // S_PLANT — GEOMETRIC COMMIT
    // ------------------------------------------------------------------------
    public func plantSpear(r: Int, c: Int, velocity: Double) {

        guard lattice[r][c] == .seeded else { return }

        lattice[r][c] = .frozen

        if velocity >= 15.0 {
            propagateFreeze(r, c)
        }

        collapseVoids()
    }
    // ------------------------------------------------------------------------
    // S_ECHO — FIXED POINT DETECTION
    // ------------------------------------------------------------------------
    public func echo() -> Bool {

        let flat = lattice.flatMap { $0 }

        let complete = flat.allSatisfy {
            $0 == .frozen || $0 == .void
        }

        return complete
    }
    // ------------------------------------------------------------------------
    // VOID QUOTIENT CLOSURE
    // ------------------------------------------------------------------------
    private func collapseVoids() {

        for r in 0..<size {
            for c in 0..<size {

                if lattice[r][c] == .empty && isOrphan(r, c) {
                    lattice[r][c] = .void
                }
            }
        }
    }

    private func isOrphan(_ r: Int, _ c: Int) -> Bool {

        return neighbors(r, c).allSatisfy {
            lattice[$0.0][$0.1] == .frozen ||
            lattice[$0.0][$0.1] == .void
        }
    }

    private func propagateFreeze(_ r: Int, _ c: Int) {

        for (nr, nc) in neighbors(r, c) {
            if lattice[nr][nc] == .seeded {
                lattice[nr][nc] = .frozen
            }
        }
    }

    private func neighbors(_ r: Int, _ c: Int) -> [(Int, Int)] {

        return [
            (r-1,c), (r+1,c), (r,c-1), (r,c+1)
        ].filter {
            $0.0 >= 0 && $0.0 < size &&
            $0.1 >= 0 && $0.1 < size
        }
    }
}
