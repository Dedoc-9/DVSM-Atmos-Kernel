        }

        return complete
    }
    // ========================================================================
    // 6. VOID QUOTIENT CLOSURE (GHOST ELIMINATION)
    // ========================================================================

    private func collapseVoids() {

        for r in 0..<n {
            for c in 0..<n {

                if L[r][c] == .empty && isOrphan(r, c) {
                    L[r][c] = .void
                }
            }
        }
    }
    private func isOrphan(_ r: Int, _ c: Int) -> Bool {

        let neighbors = self.neighbors(r, c)

        return neighbors.allSatisfy {
            L[$0.0][$0.1] >= .frozen
        }
    }
    // ========================================================================
    // 7. KINETIC PROPAGATION (ARCTIC FREEZE FRONT)
    // ========================================================================

    private func propagateFreeze(_ r: Int, _ c: Int) {

        for (nr, nc) in neighbors(r, c) {
            if L[nr][nc] == .seeded {
                L[nr][nc] = .frozen
            }
        }
    }
    // ========================================================================
    // 8. MONOTONE ENFORCEMENT
    // ========================================================================

    private func enforceMonotonicity() {

        // no downward transitions allowed
        for r in 0..<n {
            for c in 0..<n {
                if L[r][c] == .frozen && causalDepth == 0 {
                    L[r][c] = .frozen
                }
            }
        }
    }
    // ========================================================================
    // 9. NEIGHBOR RELATION (TOPOLOGICAL EDGE)
    // ========================================================================

    private func neighbors(_ r: Int, _ c: Int) -> [(Int, Int)] {

        return [
            (r-1,c),
            (r+1,c),
            (r,c-1),
            (r,c+1)
        ].filter {
            $0.0 >= 0 && $0.0 < n &&
            $0.1 >= 0 && $0.1 < n
        }
    }
