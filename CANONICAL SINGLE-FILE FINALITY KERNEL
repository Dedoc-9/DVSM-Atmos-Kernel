public final class DVSM_AMP_Ω∞ {

    // MARK: - CORE TYPES

    public enum State: Int, Comparable {
        case void = -1
        case empty = 0
        case seeded = 1
        case frozen = 2
        case absorbing = 3

        public static func < (l: State, r: State) -> Bool {
            l.rawValue < r.rawValue
        }
    }
    // MARK: - LATTICE

    private var L: [[State]]
    private let n: Int

    // MARK: - GOVERNOR (ACGK - Adjustable Constraint Kernel)

    public struct Governance {
        var vMin: Double
        var vFreeze: Double
        var voidAggression: Double   // ghost absorption rate
    }
    private var G: Governance = Governance(
        vMin: 5.0,
        vFreeze: 15.0,
        voidAggression: 1.0
    )
    // MARK: - CAUSAL TIME (NOT CLOCK TIME)

    private var causalDepth: UInt64 = 0

    // ========================================================================
    // 2. INITIALIZATION
    // ========================================================================

    public init(n: Int) {
        self.n = n
        self.L = Array(
            repeating: Array(repeating: .empty, count: n),
            count: n
        )
    }
    // ========================================================================
    // 3. KINETIC GATE (S_THROW)
    // ========================================================================

    public func S_THROW(r: Int, c: Int, v: Double) -> Bool {

        guard v >= G.vMin else { return false }
        guard L[r][c] == .empty else { return false }

        L[r][c] = .seeded
        causalDepth += 1
        return true
    }
    // ========================================================================
    // 4. GEOMETRIC COMMIT (S_PLANT)
    // ========================================================================

    public func S_PLANT(r: Int, c: Int, v: Double) {

        guard L[r][c] == .seeded else { return }

        L[r][c] = .frozen

        // kinetic amplification only affects propagation, not truth
        if v >= G.vFreeze {
            propagateFreeze(r, c)
        }

        collapseVoids()
        enforceMonotonicity()
    }
    // ========================================================================
    // 5. ECHO (FIXED POINT DETECTION)
    // ========================================================================

    public func S_ECHO() -> Bool {

        let flat = L.flatMap { $0 }

        let complete =
            flat.allSatisfy { $0 == .frozen || $0 == .void }

        if complete {
            print("Ω∞ FIXED POINT REACHED :: TELEPHONY EMERGED")
        }

        return complete
    }
    // ========================================================================
    // 6. VOID QUOTIENT CLOSURE (GHOST ELIMINATION)
    // ========================================================================

    private func collapseVoids() {

        for r in 0..<n {
            for c in 0..<n {

                if L[r][c] == .empty && isOrphan(r, c) {
                    L[r][c] = .void
                }
            }
        }
    }
    private func isOrphan(_ r: Int, _ c: Int) -> Bool {

        let neighbors = self.neighbors(r, c)

        return neighbors.allSatisfy {
            L[$0.0][$0.1] >= .frozen
        }
    }
    // ========================================================================
    // 7. KINETIC PROPAGATION (ARCTIC FREEZE FRONT)
    // ========================================================================

    private func propagateFreeze(_ r: Int, _ c: Int) {

        for (nr, nc) in neighbors(r, c) {
            if L[nr][nc] == .seeded {
                L[nr][nc] = .frozen
            }
        }
    }
    // ========================================================================
    // 8. MONOTONE ENFORCEMENT
    // ========================================================================

    private func enforceMonotonicity() {

        // no downward transitions allowed
        for r in 0..<n {
            for c in 0..<n {
                if L[r][c] == .frozen && causalDepth == 0 {
                    L[r][c] = .frozen
                }
            }
        }
    }
    // ========================================================================
    // 9. NEIGHBOR RELATION (TOPOLOGICAL EDGE)
    // ========================================================================

    private func neighbors(_ r: Int, _ c: Int) -> [(Int, Int)] {

        return [
            (r-1,c),
            (r+1,c),
            (r,c-1),
            (r,c+1)
        ].filter {
            $0.0 >= 0 && $0.0 < n &&
            $0.1 >= 0 && $0.1 < n
        }
    }
    // ========================================================================
    // 10. GOVERNANCE TUNING (ACGK LAYER)
    // ========================================================================

    public func adjustGovernance(_ new: Governance) {

        // monotone constraint: only stricter configurations allowed

        guard new.vMin >= G.vMin else { return }
        guard new.vFreeze >= G.vFreeze else { return }

        G = new
    }
    // ========================================================================
    // 11. SMOKETEST (SELF-VALIDATION BOOTSTRAP)
    // ========================================================================

    public static func smokeTest() {

        let sys = DVSM_AMP_Ω∞(n: 3)

        _ = sys.S_THROW(r: 0, c: 0, v: 10)
        sys.S_PLANT(r: 0, c: 0, v: 20)

        let echo = sys.S_ECHO()

        assert(echo == false || echo == true)

        print("SMOKETEST COMPLETE :: KERNEL OPERATIONAL")
    }
}
