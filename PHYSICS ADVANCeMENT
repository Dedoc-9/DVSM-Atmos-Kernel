 A purely syntactic bijection layer:
 
     Decode ∘ Encode = Identity (on canonical domain)
 
 No semantic interpretation is permitted at this layer.
 */

public enum DVSMHardenedMirror {

    // MARK: - CONSTANTS

    private static let expectedSize = 68

    // MARK: - BYTE SAFETY CORE

    private static func require(_ condition: Bool) -> Bool {
        return condition
    }

    // MARK: - DETERMINISTIC ASSEMBLY

    private static func assembleUInt64(_ data: Data) -> UInt64 {
        precondition(data.count == 8)
        return data.withUnsafeBytes { raw in
            raw.reduce(UInt64(0)) { ($0 << 8) | UInt64($1) }
        }
    }

    private static func assembleUInt32(_ data: Data) -> UInt32 {
        precondition(data.count == 4)
        return data.withUnsafeBytes { raw in
            raw.reduce(UInt32(0)) { ($0 << 8) | UInt32($1) }
        }
    }

    private static func assembleInt64(_ data: Data) -> Int64 {
        return Int64(bitPattern: assembleUInt64(data))
    }

    // MARK: - CANONICAL DECODER

    public static func decode(_ buffer: Data) -> DVSMDecodedPrimitive? {

        // 1. STRICT BOUNDARY ENFORCEMENT
        guard buffer.count == expectedSize else { return nil }

        // 2. SLICE CONTRACT (NO PREFIX ASSUMPTIONS)
        let idBytes       = buffer[0..<8]
        let delta0Bytes   = buffer[8..<16]
        let delta1Bytes   = buffer[16..<24]
        let delta2Bytes   = buffer[24..<32]
        let quoteBytes    = buffer[32..<64]
        let entropyBytes  = buffer[64..<68]

        // 3. SYNTACTIC RECONSTRUCTION
        let entityID = assembleUInt64(Data(idBytes))

        let deltas: [Int64] = [
            assembleInt64(Data(delta0Bytes)),
            assembleInt64(Data(delta1Bytes)),
            assembleInt64(Data(delta2Bytes))
        ]

        let quote = Data(quoteBytes)
        let entropy = assembleUInt32(Data(entropyBytes))

        // 4. OUTPUT (PURE STRUCTURAL OBJECT)
        return DVSMDecodedPrimitive(
            entityID: entityID,
            delta: deltas,
            quote: quote,
            entropyClass: entropy
        )
    }

    // MARK: - FORMAL ROUND-TRIP CHECK

    public static func verifyRoundTrip(_ buffer: Data) -> Bool {
        guard let decoded = decode(buffer) else { return false }

        let reencoded = DVSMCanonicalLock.lock(
            entityID: decoded.entityID,
            delta: decoded.delta,
            quote: decoded.quote,
            entropy: decoded.entropyClass
        )

        return buffer == reencoded
    }
}
