    public static func isKinematicallyValid(_ delta: [Int64], pulseWidth: Int64) -> Bool {
        
        // 1. WIDENED ENERGY ACCUMULATION (Prevent Overflow)
        // We use a conceptual 128-bit accumulator to handle 32.32 squaring
        let dx = Int128(delta[0])
        let dy = Int128(delta[1])
        let dz = Int128(delta[2])
        
        let squaredEnergy = (dx*dx) + (dy*dy) + (dz*dz)
        
        // 2. TIME-NORMALIZED VELOCITY BOUND
        // Limit = (C * Δt)²
        let v_max = Int128(c_limit) * Int128(pulseWidth)
        let energyLimit = v_max * v_max
        
        // 3. THE CONE CONSTRAINT
        // Rejects any transition outside the reachable light-cone of the pulse
        return squaredEnergy <= energyLimit
    }
