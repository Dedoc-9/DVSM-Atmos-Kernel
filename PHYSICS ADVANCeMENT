extension DVSMThermalBreathVerifier {

    /**
     # PRECISION-ALIGNED PERTURBATION
     Uses bit-shifted entropy to ensure identical jitter scaling
     across ARM and x86 floating-point manifolds.
     */
    public func generateDeterministicProbe(seed: UInt64) -> Double {
        let hashed = SHA256.hash(data: withUnsafeBytes(of: seed.bigEndian) { Data($0) })
        let sample = hashed.prefix(8).withUnsafeBytes { $0.load(as: UInt64.self).bigEndian }
        
        // 53-bit alignment for IEEE 754 parity
        let normalizedSeed = Double(sample >> 11) / Double(UInt64.max >> 11)
        
        return normalizedSeed * 0.01
    }
}
