import Foundation

/**
 # L2.2 SPATIAL CONTRACT (FINAL)

 This module defines a deterministic spatial equivalence system,
 not a geometric truth system.

 CORE PRINCIPLES:

 1. EQUIVALENCE CLASS MODEL
    Each voxel represents a finite spatial region.
    decode() returns the CANONICAL REPRESENTATIVE (center anchor).

 2. ORIGIN RELATIVITY (GLOBAL INVARIANT)
    coordinateOffset defines the universal origin shift.
    It is part of the L0–L5 replay contract.

 3. RESOLUTION CEILING
    axisMask defines a hard 21-bit spatial resolution limit.
    All coordinates outside this space are invalid (L6 fracture).

 4. MIDPOINT CANONICALIZATION
    All decoded coordinates are normalized to voxel centers
    to ensure deterministic replay equivalence.
 */

public enum DVSMMortonEngine {

    // MARK: - GLOBAL SPATIAL CONTRACT CONSTANTS

    /// 21-bit axis resolution ceiling (2,097,152 discrete units per axis)
    public static let axisMask: UInt64 = 0x1F_FFFF

    /// Global origin shift (fixed-point world centering constant)
    /// NOTE: This value is part of the cryptographic replay contract.
    public static let coordinateOffset: Int64 = 1 << 40

    /// Canonical voxel midpoint bias (ensures deterministic anchoring)
    private static let halfVoxel: Int64 = 1 << 31

    // MARK: - ENCODE (3D → MORTON KEY)

    /**
     Converts signed 32.32 fixed-point coordinates into a Morton key.
     This defines the spatial equivalence class identity.
     */
    public static func encode(x: Int64, y: Int64, z: Int64) -> UInt64 {

        // Normalize into unsigned voxel index space
        let ux = UInt64(bitPattern: (x + coordinateOffset) >> 32) & axisMask
        let uy = UInt64(bitPattern: (y + coordinateOffset) >> 32) & axisMask
        let uz = UInt64(bitPattern: (z + coordinateOffset) >> 32) & axisMask

        return interleave(ux) | (interleave(uy) << 1) | (interleave(uz) << 2)
    }

    // MARK: - DECODE (MORTON KEY → CANONICAL VOXEL ANCHOR)

    /**
     Returns the canonical voxel center.

     IMPORTANT:
     - This is NOT a lossless inverse.
     - This is a deterministic representative mapping.
     */
    public static func decode(_ key: UInt64) -> SIMD3<Int64> {

        let x = deinterleave(key)
        let y = deinterleave(key >> 1)
        let z = deinterleave(key >> 2)

        return SIMD3<Int64>(
            canonicalize(x),
            canonicalize(y),
            canonicalize(z)
        )
    }

    // MARK: - CANONICALIZATION (VOXEL CENTER MAPPING)

    /**
     Converts voxel index → deterministic center point in world space.
     This ensures all nodes converge on identical spatial representation.
     */
    private static func canonicalize(_ value: UInt64) -> Int64 {
        let base = (Int64(bitPattern: value) << 32)
        return (base - coordinateOffset) + halfVoxel
    }

    // MARK: - MORTON INTERLEAVE

    private static func interleave(_ n: UInt64) -> UInt64 {
        var x = n & axisMask
        x = (x | x << 32) & 0x1f00000000ffff
        x = (x | x << 16) & 0x1f0000ff0000ff
        x = (x | x << 8)  & 0x100f00f00f00f00f
        x = (x | x << 4)  & 0x10c30c30c30c30c3
        x = (x | x << 2)  & 0x1249249249249249
        return x
    }

    // MARK: - MORTON DEINTERLEAVE

    private static func deinterleave(_ n: UInt64) -> UInt64 {
        var x = n & 0x1249249249249249
        x = (x | x >> 2)  & 0x10c30c30c30c30c3
        x = (x | x >> 4)  & 0x100f00f00f00f00f
        x = (x | x >> 8)  & 0x1f0000ff0000ff
        x = (x | x >> 16) & 0x1f00000000ffff
        x = (x | x >> 32) & axisMask
        return x
    }
}
