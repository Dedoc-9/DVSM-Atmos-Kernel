/**
 # L0.1: GENESIS RECONCILIATION (MAJORITY RULE)
 
 A node may only proceed to L1 ignition if:
 - A strict majority fingerprint exists
 - The local fingerprint matches that majority class
 - Consensus is deterministic (no tie ambiguity allowed)
 */

public struct DVSML0Fingerprint: Hashable, Equatable {
    public let genesisHash: Data
    public let substrateAxioms: Data
}

public final class DVSMGenesisReconciler {
    
    private var observedFingerprints: [UUID: DVSML0Fingerprint] = [:]
    
    /// Record network observations
    public func observe(nodeID: UUID, fingerprint: DVSML0Fingerprint) {
        observedFingerprints[nodeID] = fingerprint
    }
    
    /**
     # DETERMINISTIC MAJORITY CONSENSUS
     Returns true iff local fingerprint matches strict majority cluster.
     */
    public func isConsensusValid(localFingerprint: DVSML0Fingerprint) -> Bool {
        
        let all = Array(observedFingerprints.values) + [localFingerprint]
        
        // Group identical fingerprints
        let grouped = Dictionary(grouping: all, by: { $0 })
        
        // Find (fingerprint, count) pairs
        let counted = grouped.map { (key, value) in
            (fingerprint: key, count: value.count)
        }
        
        // Deterministic tie-break: highest count, then lexicographic hash
        let sorted = counted.sorted { a, b in
            if a.count == b.count {
                return a.fingerprint.genesisHash.lexicographicallyPrecedes(
                    b.fingerprint.genesisHash
                )
            }
            return a.count > b.count
        }
        
        guard let majority = sorted.first else {
            return false
        }
        
        let hasStrictMajority = majority.count > all.count / 2
        let localAligned = (localFingerprint == majority.fingerprint)
        
        return hasStrictMajority && localAligned
    }
}
