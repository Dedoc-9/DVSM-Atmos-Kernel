// L2.3_SPATIOTEMPORAL_COLLISION.swift
// VERSION: CAUSAL-PATH-INTEGRITY-V1.1 (V-DDA FIXED)
// ROLE: Voxel-Boundary Accurate Collision Sweep
// =====================================================

import Foundation

public enum DVSMCollisionField {

    /**
     # VOXEL-ACCURATE CAUSAL SWEEP (V-DDA)
     Traverses voxel boundaries deterministically without sampling loss.
     */
    public static func validatePath(
        start: SIMD3<Int64>,
        delta: SIMD3<Int64>,
        manifold: DVSMSparseVoxelMap
    ) -> Bool {

        let end = start &+ delta

        // Convert to voxel space (32.32 → voxel index)
        let voxelStart = voxelCoordinate(start)
        let voxelEnd   = voxelCoordinate(end)

        var current = voxelStart

        let stepX = sign(voxelEnd.x - voxelStart.x)
        let stepY = sign(voxelEnd.y - voxelStart.y)
        let stepZ = sign(voxelEnd.z - voxelStart.z)

        // Compute voxel traversal bounds
        let dx = abs(voxelEnd.x - voxelStart.x)
        let dy = abs(voxelEnd.y - voxelStart.y)
        let dz = abs(voxelEnd.z - voxelStart.z)

        let n = max(dx, max(dy, dz))
        if n == 0 {
            return !manifold.isOccupied(at: current)
        }

        // Digital voxel traversal (no interpolation drift possible)
        for _ in 0...n {

            if manifold.isOccupied(at: current) {
                return false // CAUSAL BLOCKAGE
            }

            current = SIMD3<Int64>(
                current.x + stepX,
                current.y + stepY,
                current.z + stepZ
            )
        }

        return !manifold.isOccupied(at: voxelEnd)
    }

    // MARK: - VOXEL NORMALIZATION

    private static func voxelCoordinate(_ p: SIMD3<Int64>) -> SIMD3<Int64> {
        SIMD3<Int64>(
            p.x >> 32,
            p.y >> 32,
            p.z >> 32
        )
    }

    private static func sign(_ v: Int64) -> Int64 {
        v > 0 ? 1 : (v < 0 ? -1 : 0)
    }
}
