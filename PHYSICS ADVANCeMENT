/**
 # L1 INTENT NORMALIZATION AXIOM

 All external inputs are treated as untrusted stochastic signals.

 They are mapped into a fixed 32.32 fixed-point canonical space
 BEFORE any POCR / L2 filtering occurs.
 */

public struct DVSMIntent {
    public let canonicalHash: Data
    public let fixedPointVector: Int64
    public let entropyClass: UInt8
}

public enum DVSMIntentNormalizer {

    /// Canonical fixed-point scale (32.32)
    private static let scale: Int64 = 1 << 32

    /**
     # PRIMARY NORMALIZATION OPERATOR

     Converts raw external input into deterministic internal intent space.
     */
    public static func normalize(_ input: Data) -> DVSMIntent {

        // 1. Hash input into deterministic entropy base
        let hash = SHA256.hash(data: input)

        // 2. Extract 64-bit segment for fixed-point projection
        let raw = hash.prefix(8).withUnsafeBytes { $0.load(as: UInt64.self) }

        // 3. Map into signed 32.32 space
        let fixedPoint = Int64(bitPattern: raw) / scale

        // 4. Classify entropy intensity (coarse-grained security tag)
        let entropyClass = hash.first ?? 0

        return DVSMIntent(
            canonicalHash: Data(hash),
            fixedPointVector: fixedPoint,
            entropyClass: entropyClass
        )
    }
}
