// MARK: - CAUSAL REGIME OPTIMIZER

public final class SRERegimeOptimizer {
    
    /**
     # PRINCIPLE: CAUSAL GRADIENT DESCENT
    
     Instead of updating weights:
     we perturb physical boundary conditions
     and observe changes in output geometry.
     */
    
    public func step(
        errorGradient: Double,
        current: StabilityEnvelope
    ) -> StabilityEnvelope {
        
        // Convert error into controlled physical perturbation
        let delta = bounded(errorGradient)
        
        // Adjust system toward higher separability regime
        let newGasDensity = current.gasDensity + (delta * 0.3)
        
        // Pressure shift controls nonlinear stiffness of collapse
        let newPressure = current.pressureField + (delta * 0.6)
        
        // Collapse radius tunes proximity to instability threshold
        let newRadius = current.collapseRadius - (delta * 0.2)
        
        // Sonic limit defines causal boundary (reachability frontier)
        let newSonicLimit = current.sonicLimit + (delta * 0.5)
        
        return StabilityEnvelope(
            gasDensity: newGasDensity,
            pressureField: newPressure,
            collapseRadius: newRadius,
            sonicLimit: newSonicLimit,
            signatureSeparability: predictSeparability(delta, current)
        )
    }
    
    // MARK: - PHYSICAL OBJECTIVE FUNCTION
    
    /**
     Higher separability = better computational resolution
     of emission signatures between different inputs.
     */
    private func predictSeparability(_ delta: Double, _ state: StabilityEnvelope) -> Double {
        let instability = abs(delta) * state.pressureField
        return min(1.0, state.signatureSeparability + instability * 0.01)
    }
    
    private func bounded(_ x: Double) -> Double {
        return max(-1.0, min(1.0, x))
    }
}

