public final class DVSMKernel {

    // AUTHORITATIVE STATE
    private var state: DVSMBitBlock
    private var sequence: UInt64 = 0

    // DETERMINISTIC LOCK (single authority gate)
    private let commitLock = NSLock()

    public init(initialState: DVSMBitBlock) {
        self.state = initialState
    }

    // =====================================================
    // CORE PULSE (THE ONLY REALITY MUTATOR)
    // =====================================================

    public func pulse(_ input: DVSMFixedVector) -> DVSMCommitResult {

        commitLock.lock()
        defer { commitLock.unlock() }

        // 1. Propose deterministic next state
        let candidate = DVSMLaw.propose(
            current: state,
            flux: input
        )

        // 2. Semantic decision (pure, deterministic)
        let accepted = DVSMKernel.evaluate(state, candidate)

        // 3. Sequence ALWAYS advances (critical invariant)
        sequence += 1

        if accepted {

            state = candidate

            let hash = DVSMKernel.hash(state, sequence)

            return .committed(hash)

        } else {

            let rejectionState = DVSMKernel.reject(state, sequence)

            let hash = DVSMKernel.hash(rejectionState, sequence)

            return .rejected(hash)
        }
    }
}
