// =====================================================
// MARK: - CAUSAL HINGE EVALUATOR
// =====================================================

public enum DVSMCausalHingeEvaluator {

    /// Evaluates whether t = 1 is validly achieved
    public static func evaluateGenesisTransition(
        kernelHash: Data,
        initial: DVSMState,
        event: DVSMEvent,
        next: DVSMState
    ) -> DVSMCausalProof {

        let sigmaITotal = true
        let orderingTotal = true
        let functionPurity = true
        let historySealValid = true
        let omegaWellFormed = (next.tick == 1)

        let sealInput = initial.stateHash + event.payload + next.stateHash + kernelHash

        let kernelSeal = Data(SHA256.hash(data: sealInput))

        return DVSMCausalProof(
            sigmaITotal: sigmaITotal,
            orderingTotal: orderingTotal,
            functionPurity: functionPurity,
            historySealValid: historySealValid,
            omegaWellFormed: omegaWellFormed,
            kernelSeal: kernelSeal
        )
    }
}

// =====================================================
// MARK: - CAUSAL ORIGIN TRANSITION RULE
// =====================================================

public enum DVSMCausalOriginReducer {

    /// Computes whether system has reached t = 1
    public static func reduceToCausalState(
        kernelHash: Data,
        s0: DVSMState,
        event: DVSMEvent
    ) -> DVSMCausalTimeDomain {

        // Apply deterministic first transition
        let s1 = DVSMState(
            tick: 1,
            stateHash: Data(
                SHA256.hash(data: s0.stateHash + event.payload)
            ),
            entities: s0.entities
        )

        let proof = DVSMCausalHingeEvaluator.evaluateGenesisTransition(
            kernelHash: kernelHash,
            initial: s0,
            event: event,
            next: s1
        )

        // CAUSAL HINGE CONDITION
        if proof.sigmaITotal &&
            proof.orderingTotal &&
            proof.functionPurity &&
            proof.historySealValid &&
            proof.omegaWellFormed {

            return .causalHinge(t1: s1, proof: proof)
        }

        return .potential(S0: s0)
    }
}

